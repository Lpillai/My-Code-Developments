@model RuntimeVariables.SO_item_inquiry




<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: Arial, Helvetica, sans-serif;
    }

    /* Float four columns side by side */
    .column {
        float: left;
        width: 49%;
        padding: 0 10px;
    }

    /* Remove extra left and right margins, due to padding */
    .row {
        margin: 0 -5px;
    }
        /* Clear floats after the columns */
        .row:after {
            content: "";
            display: table;
            clear: both;
        }

    .card {
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
        padding: 16px;
        text-align: left;
        background-color: #f1f1f1;
    }

    div.display {
        padding: 5px 0 0 0;
        font-size: large;
    }
</style>




<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&Chi;</span>
    </button>
        
    <div class="form-group" style="margin-bottom: -5px; padding-left: 5px;">
        <h3 style="margin-top: 0px; font-family: Calibri, Helvetica, sans-serif;">
            (@ViewData["pm_loc_id"]) @Model.item_id
        </h3>
        <span style="font-size: medium;"> 
            @Html.DisplayFor(model => model.item_desc)
        </span>
    </div>
</div>
<div class="modal-body">
    <div class="row">
        <div class="column" style="margin-left: 7px;">
            <div class="card">
                <h4 style="margin-top: 0px;">
                    @Html.Raw("Availability")
                </h4>
                <div class="form-horizontal">
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_hand, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_hand)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_allocated, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_allocated)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_backordered, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_backordered)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_non_pickable, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_non_pickable)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_quarantined, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_quarantined)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_frozen, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_frozen)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_available, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_available)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_release_schedule, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_release_schedule)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_future_orders, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_future_orders)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.net_qty_available, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.net_qty_available)
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="form-horizontal">
            <div class="column">
                <div class="card">
                    <h4 style="margin-top: 0px;">
                        @Html.Raw("In Flows")
                    </h4>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_purchase_order, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_purchase_order)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_in_vessel, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_in_vessel)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_transfer, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_transfer)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_production_orders, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_production_orders)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_secondary_process, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_secondary_process)
                        </div>
                    </div>
                </div>
            </div>
            <div class="column" style="margin-top: 12px;">
                <div class="card">
                    <h4 style="margin-top: 0px;">
                        @Html.Raw("Out Flows")
                    </h4>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_to_transfer, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_to_transfer)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_for_production, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_for_production)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_for_secondary_process, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_for_secondary_process)
                        </div>
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.qty_on_sales_order, htmlAttributes: new { @class = "control-label col-md-8" })
                        <div class="col-md-4 display">
                            @Html.DisplayFor(model => model.qty_on_sales_order)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

