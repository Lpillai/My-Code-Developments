@model RuntimeVariables.BOM_ProcureInfo

@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}




<script type="text/javascript"> 
</script>




@using (Html.BeginForm("GoPostNewBuy_BOM_ASMLTW", "Sales", FormMethod.Post, new { id = "PurchaseForm", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&Chi;</span>
        </button>
        <h4 class="modal-title">
            <span>@Model.customer_part_no</span>
        </h4>
    </div>
    <div class="modal-body">
        <div class="form-horizontal" style="font-size: medium; margin-top: 5px;">
            <div class="form-group">
                @Html.HiddenFor(model => model.item_id)
                @Html.LabelFor(model => model.item_id, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right;" })
                @Html.DisplayFor(model => model.item_id)
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.SupplierName, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right;" })
                @Html.DisplayFor(model => model.SupplierName)
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.LeadTime, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right;" })
                @Html.DisplayFor(model => model.LeadTime)
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.OrderMinQty, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right;" })
                @Html.DisplayFor(model => model.OrderMinQty)
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.ShortageWeek, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right;" })
                @Html.DisplayFor(model => model.ShortageWeek)
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.RequireDate, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin-top: 5px;" })
                @Html.TextBoxFor(model => model.RequireDate, new { @type = "date", @class = "form-control datepicker", @Value = Model.RequireDate.ToString("yyyy-MM-dd"), @style = "font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.BuyQty, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin-top: 5px;" })
                @Html.EditorFor(model => model.BuyQty, new { htmlAttributes = new { @class = "form-control", @style = "text-align: right; font-size: medium;" } })
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <input type="submit" value="Purchase" class="btn btn-primary" onclick="return confirm('Post a new buy?');" @attr_html />
    </div>
}

