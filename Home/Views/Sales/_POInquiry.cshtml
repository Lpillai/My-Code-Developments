@model IEnumerable<RuntimeVariables.BOM_income>




<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: Arial, Helvetica, sans-serif;
    }

    .tableScrollY {
        overflow: auto;
        display: inline-block;
        width: 100%;
    }
</style>




<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&Chi;</span>
    </button>
        
    <div class="form-group" style="margin-bottom: -5px; padding-left: 5px;">
        <h3 style="margin-top: 0px; font-family: Calibri, Helvetica, sans-serif;">
            @ViewData["ModalTitle"]
        </h3>
    </div>
</div>
<div class="modal-body">
    <div id="theSheet" class="tableScrollY">
        <table class="table table-hover" style="table-layout: fixed;">
            <colgroup>
                <col style="width: 25px;">
                <col style="width: 80px;">
                <col style="width: 100px;">
                <col style="width: 90px;">
            </colgroup>
            <thead>
                <tr>
                    <th style="text-align: center;">
                        @Html.Raw(((Model == null || Model.Count() == 0) ? 0 : Model.Count()).ToString())
                    </th>
                    <th style="text-align: center;">
                        @Html.DisplayNameFor(model => model.po_no)
                    </th>
                    <th style="text-align: center;">
                        @Html.DisplayNameFor(model => model.expected_date)
                    </th>
                    <th style="text-align: center;">
                        @Html.DisplayNameFor(model => model.po_qty)
                    </th>
                </tr>
            </thead>
            <tbody>
                @{
                    if (Model == null || Model.Count() <= 0)
                    { 
                        <tr>
                            <td colspan="4" style="text-align:center;">No data found.</td>
                        </tr>
                    }
                    else
                    {
                        int i = 0;
                        foreach (var item in Model)
                        {
                            i++;
                            <tr>
                                <td align="right">
                                    @Html.Raw(i)
                                </td>
                                <td align="center">
                                    @if (string.IsNullOrWhiteSpace(item.entryID) || item.entryID == "")
                                    {
                                        @Html.DisplayFor(modelItem => item.po_no)
                                    }
                                     else
                                    {
                                        @Html.ActionLink(item.po_no, "EditBuy", "Procurement", new { cluster = item.cluster, pm_entryId = item.entryID }, new { target = "_blank" })
                                    }
                                </td>
                                <td align="center">
                                    @Html.DisplayFor(modelItem => item.expected_date)
                                </td>
                                <td align="right" style="padding-right: 10px;">
                                    @Html.DisplayFor(modelItem => item.po_qty)
                                </td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>
    </div>
</div>

