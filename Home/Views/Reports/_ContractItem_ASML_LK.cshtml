<style>
</style>




<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("Open_ContractItem_ASML_LK", "Reports", null, FormMethod.Post, new { enctype = "multipart/form-data", target="_blank" }))
{ 
    @Html.AntiForgeryToken()
    @Html.Hidden("pm_label", ViewData["label"].ToString())
    @Html.Hidden("pm_job_no", ViewData["pm_job_no"].ToString())
    @Html.Hidden("pm_ship_to_id", ViewData["pm_ship_to_id"].ToString())
    
    <div class="form-horizontal" style="width: 500px; margin-left: 15px;">
        <div class="form-group">
            @Html.Label("Contract Bin ID", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="text" id ="pm_contract_bin_id" name ="pm_contract_bin_id" value="" autocomplete ="off" onfocus = "this.select()" class="form-control" />
            </div>
        </div>
        <div class="form-group" style="margin-right: 10%; text-align: right;">
            <input type="submit" id="btn_print" value="Print" class="btn btn-primary" />
        </div>
    </div>
}
