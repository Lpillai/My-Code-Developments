<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("Open_BRPProduction", "Reports", null, FormMethod.Post, new { enctype = "multipart/form-data", target = "_blank" }))
{
    @Html.AntiForgeryToken()
    @Html.Hidden("pm_label", ViewData["label"].ToString())
    @Html.Hidden("pm_job_no", ViewData["job_no"].ToString())

    <div class="form-horizontal" style="width: 500px; margin-left: 15px;">

        <div class="form-group">
            @Html.Label("Item ID", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="text" name="pm_item_id" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Lot No", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="text" name="pm_lot_no" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            @Html.Label("Qty", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="number" name="pm_qty" class="form-control" />
            </div>
        </div>

        <div class="form-group" style="margin-right: 10%; text-align: right;">
            <input type="submit" value="Print" class="btn btn-primary" />
        </div>

    </div>
}