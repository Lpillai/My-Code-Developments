<style type="text/css">
</style>




<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("Open_QC_SampleProcess", "Reports", null, FormMethod.Post, new { enctype = "multipart/form-data", target="_blank" }))
{ 
    @Html.AntiForgeryToken()
    @Html.Hidden("pm_label", ViewData["label"].ToString())
    
    <div class="form-horizontal" style="width: 500px; margin-left: 15px;">
        <div class="form-group">
            @Html.Label("PO number", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="number" id ="po_no" name ="po_no" autofocus autocomplete="off" class="form-control" />
            </div>
        </div>
        <div class="form-group">
            @Html.Label("Line number", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="number" id ="line_no" name ="line_no" autofocus autocomplete="off" class="form-control" />
            </div>
        </div>
        <div class="form-group" style="margin-right: 10%; text-align: right;">
            <input type="submit" id="btn_print" value="Print" class="btn btn-primary" />
        </div>
    </div>
}
