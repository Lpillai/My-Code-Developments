<style type="text/css">
</style>




<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("Open_LocationBins", "Reports", null, FormMethod.Post, new { enctype = "multipart/form-data", target="_blank" }))
{ 
    @Html.AntiForgeryToken()
    @Html.Hidden("pm_label", ViewData["label"].ToString())
    @Html.Hidden("pm_loc_grp", ViewData["pm_loc_grp"].ToString())
    
    <div class="form-horizontal" style="width: 500px; margin-left: 15px;">
        <div class="form-group">
            @Html.Label("Bin ID Start", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="text" id ="bin_id_start" name ="bin_id_start" autofocus class="form-control" />
            </div>
        </div>
        <div class="form-group">
            @Html.Label("Bin ID End", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="text" id ="bin_id_end" name ="bin_id_end" autofocus class="form-control" />
            </div>
        </div>
        <div class="form-group">
            @Html.Label("Font Size", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                @Html.DropDownList("font_size", new SelectList((IEnumerable<SelectListItem>)ViewData["FontSize"], "Value", "Text", "48"), new { @class = "form-control", style="font-size: medium; min-width: 60px; max-width: 60px;" })
            </div>
        </div>
        <div class="form-group" style="margin-right: 10%; text-align: right;">
            <input type="submit" id="btn_print" value="Print" class="btn btn-primary" />
        </div>
    </div>
}
