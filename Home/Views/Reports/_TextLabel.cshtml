<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("Open_Textlabel", "Reports", null, FormMethod.Post, new { enctype = "multipart/form-data", target = "_blank" }))
{
    @Html.AntiForgeryToken()
    @Html.Hidden("pm_label", ViewData["label"].ToString())
    
    <div class="form-horizontal" style="width: 500px; margin-left: 15px;">

        <div class="form-group">
            @Html.Label("Text", new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <textarea name="pm_text" autofocus rows="5" cols="100" class="form-control" style="font-size: medium;"></textarea>
            </div>
        </div>

        <div class="form-group" style="text-align:right;">
            <input type="submit" value="Print" class="btn btn-primary" />
        </div>
    </div>
}