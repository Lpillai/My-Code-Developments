<style type="text/css">
</style>




<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("Open_SupplierScorecard", "Reports", null, FormMethod.Post, new { enctype = "multipart/form-data", target="_blank" }))
{ 
    @Html.AntiForgeryToken()
    
    <div class="form-horizontal" style="width: 500px; margin-left: 15px;">
        <div class="form-group">
            @Html.Label("Supplier", htmlAttributes: new { @class = "control-label col-md-5" })
            <div class="col-md-7">
                <input type="number" id ="pm_supplier_id" name ="pm_supplier_id" class="form-control" style="font-size: medium;" />
            </div>
        </div>
        <div class="form-group">
            @Html.Label("Target Decrease Percentage", htmlAttributes: new { @class = "control-label col-md-5" })
            <div class="col-md-7">
                <input type="number" id ="pm_target" name ="pm_target" value="5" class="form-control" style="text-align: right; font-size: medium;" />
            </div>
        </div>
        <div class="form-group" style="margin-right: 10%; text-align: right;">
            <input type="submit" id="btn_print" value="Download" class="btn btn-primary" />
        </div>
    </div>
}
