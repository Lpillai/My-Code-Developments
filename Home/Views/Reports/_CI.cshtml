<style type="text/css">
</style>




<script type="text/javascript">
    $(document).ready(function () {    
    })
</script>




<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("GoDownLoad_CI", "Reports", new { pm_cluster = @ViewBag.cluster }, FormMethod.Post, new { id = "fileform", enctype = "multipart/form-data", target="_blank" }))
{
    @Html.AntiForgeryToken()

    <div class="form-inline form-group">
        @Html.Label("Pick Ticket No", htmlAttributes: new { @class = "control-label", style = "" })
        &nbsp;
        <input type="text" name="pmPickTickets" size="120" autocomplete="off" class="form-control" style="font-size: medium; width: 600px; max-width: 600px;" />
    </div>
    <div class="form-inline form-group">
        @Html.Label("Expand Kits", htmlAttributes: new { @class = "control-label", @style = "margin: 0;" })
        &nbsp;&nbsp;&nbsp;&nbsp;
        <input type="radio" id="NoKits" name="isKits" value=false checked >
        <label for="NoKits">No</label>
        &nbsp;&nbsp;
        <input type="radio" id="YesKits" name="isKits" value=true>
        <label for="YesKits">Yes</label>
    </div>
    <div class="form-inline form-group">
        @Html.Label("UOM", htmlAttributes: new { @class = "control-label", @style = "margin: 0;" })
        &nbsp;&nbsp;&nbsp;&nbsp;
        <input type="radio" id="uom1" name="isUOM100" value=false checked >
        <label for="uom1">1</label>
        &nbsp;&nbsp;
        <input type="radio" id="uom100" name="isUOM100" value=true>
        <label for="uom100">100</label>
    </div>
    <div class="form-inline form-group" style="text-align: right;">
        <input type="submit" class="btn btn-primary" value="Download" />
    </div>
}


<div id="output">
    <div style="font-size: larger; color: darkorange;">
        @Html.Raw("※ Please delimit each pick ticket number with a comma. For instance: '3469426, 3470622, 3469427'.")
        <br>
        @Html.Raw("※ Please do NOT hit the ENTER key on this screen.")
    </div>
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

