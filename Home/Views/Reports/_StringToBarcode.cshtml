<style type="text/css">
</style>




<h4 style="margin: 0 0 20px 20px;">
    @ViewBag.ReportName
</h4>




@using (Html.BeginForm("Open_StringToBarcode", "Reports", null, FormMethod.Post, new { enctype = "multipart/form-data", target="_blank" }))
{ 
    @Html.AntiForgeryToken()
    @*@Html.Hidden("pm_label", ViewData["label"].ToString())*@
    
    <div class="form-horizontal" style="width: 500px; margin-left: 15px;">
        <div class="form-group">
            @Html.Label("Barcode Type", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                @Html.DropDownList("pm_kind", new SelectList((IEnumerable<SelectListItem>)ViewData["KindList"], "Value", "Text"), new { @class = "form-control", style="font-size: medium; min-width: 160px; max-width: 240px;" })
            </div>
        </div>
        <div class="form-group">
            @Html.Label("Text", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9">
                <input type="text" id ="pm_string" name ="pm_string" autofocus class="form-control" />
            </div>
        </div>
        <div class="form-group">
            @Html.Label("Print text also", htmlAttributes: new { @class = "control-label col-md-3" })
            <div class="col-md-9" style="padding-top: 7px;">
                <input type="radio" id="NoText" name="isText" value=false>
                <label for="NoText">No</label>
                &nbsp;&nbsp;
                <input type="radio" id="WithText" name="isText" value=true checked >
                <label for="WithText">Yes</label>
            </div>
        </div>
        <div class="form-group" style="margin-right: 10%; text-align: right;">
            <input type="submit" id="btn_print" value="Print" class="btn btn-primary" />
        </div>
    </div>
}
