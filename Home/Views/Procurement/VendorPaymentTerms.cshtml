@using RuntimeVariables;
@model IEnumerable<Vendor_PaymentTerms>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;
}




<script type="text/javascript">
</script>




<style>
    .tableScrollY {
        overflow-y: auto;
        /*display: inline-block;*/
        height: calc(100vh - 125px);
        margin: auto;
        padding-right: 10px;
        /*max-width: 1200px;*/
    }

    thead tr th {
        position: sticky;
        top: 0;
        background: #eee;
        text-align: center;
        z-index: 1;
    }

    tbody td {
        font-size: medium;
    }

    .table > tbody > tr > td {
        vertical-align: middle;
    }

    .table-hover tbody tr:hover td,
    .table-hover tbody tr:hover th {
        background-color: rgb(255 205 143 / 0.2);
    }
</style>




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>




<div id="theSheet" class="tableScrollY">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>
                    @Html.Raw(((Model == null || Model.Count() == 0) ? 0 : Model.Count()).ToString())
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.company_id)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.vendor_id)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.vendor_name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.phys_country)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.terms_desc)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.default_invoice_desc)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.date_created)
                </th>
            </tr>
        </thead>
        <tbody>
            @{
                if (Model == null || Model.Count() <= 0)
                { 
                    <tr>
                        <td colspan="8" style="text-align:center;">No data found.</td>
                    </tr>
                }
                else
                {
                    int i = 0;
                    foreach (var item in Model)
                    {
                        i++;
                        <tr>
                            <td align="right">
                                @Html.Raw(i)
                            </td>
                            <td align="center">
                                @Html.DisplayFor(modelItem => item.company_id)
                            </td>
                            <td align="center">
                                @Html.DisplayFor(modelItem => item.vendor_id)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.vendor_name)
                            </td>
                            <td align="center">
                                @Html.DisplayFor(modelItem => item.phys_country)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.terms_desc)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.default_invoice_desc)
                            </td>
                            <td align="center">
                                @Html.DisplayFor(modelItem => item.date_created)
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>


@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

