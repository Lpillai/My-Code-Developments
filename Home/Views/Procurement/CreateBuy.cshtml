                <div class="card">
                    <h3 style="text-align: center; margin-bottom: 10px;">Planning</h3>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.new_quantity, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7">
                            <input type="number" id="new_quantity" name="new_quantity" value="@Model.new_quantity" autocomplete="off" onclick="$(this).select();" onfocusout="total();" class="form-control input-sm" style="font-size: medium;" />
                            @Html.ValidationMessageFor(model => model.new_quantity, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="form-group perline">
