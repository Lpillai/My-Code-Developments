        <!-- #region Quotations -->
        <div class="row">
            <div id="Quotations" style="float: left; width: 98%; padding: 20px 10px 3px 10px;">
                <div class="card">
                    <h3 style="text-align: center;">Quotations</h3>

                    <p style="color: brown; font-size: medium; margin: 5px 0 4px 10px;">
                        @Html.Raw("※ Once a supplier/vendor got approved, \"Expected Date\" will be calculated again automatically base on the supplier's country and \"PO to Loc\".")
                    </p>
                    
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th style="text-align: center; padding: 0; margin: 0;">
                                    @Html.Hidden("QuoteCount", Model.theQuotes.Count().ToString(), null)
                                    @if (ViewBag.cluster != "FTB")
                                    {
                                        <a class="btn" style="font-size: 18px; padding: 0; margin: 0;" @(!(bool)ViewData["EnableRequired"] ? "disabled" : "") onclick="AppendFunc()">&#10010;</a>
                                    }
                                </th>
                                <th style="text-align: center;">
                                    @((Model.theQuotes.Count()-1).ToString())
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().supplier_id)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().vendor_id)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().unit_price) @(ViewBag.cluster == "Domestic" ? "(EA)" : "(C)") 
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().currency_id)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().price_diff)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().tariff)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().price_all_in)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().moq)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().lead)
                                </th>
                                <th style="text-align: center;">
                                    @Html.DisplayNameFor(model => model.theQuotes.First().supplier_info)
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                foreach (var item in Model.theQuotes)
                                {
                                    <tr id="Quote_@item.quote_seq" class="quotes" style="display: @(item.quote_seq == 0 ? "none" : "table-row");">
                                        <td align="center">
                                            @if (ViewBag.cluster != "FTB")
                                            {
                                                <a id="herf_@item.quote_seq" class="btn" @((item.quote_seq < Model.theQuotes.Count() - 1) ? "disabled" : "") style="font-size: 18px; padding: 0; margin: 5px 0 0 0;" onclick="RemoveFunc(@item.quote_seq)">@("\u2718")</a>
                                            }
                                        </td>
                                        <td align="center">
                                            <input type="number" id="theQuotes_@(item.quote_seq)__quote_seq" name="theQuotes[@item.quote_seq].quote_seq" value="@item.quote_seq" readonly class="hideBorder" style="display: inline; text-align: right; font-size: medium; min-width: 25px; max-width: 25px;" />
                                            &nbsp;&nbsp;
                                            @Html.DropDownList($"theQuotes[{item.quote_seq}].z_status", (IEnumerable<SelectListItem>)ViewData["StatusList"], new { onchange = $"CheckApprove({item.quote_seq});", @class = "form-control detailSelect", style="display: inline; font-size: medium; min-width: 120px; max-width: 120px;" })
                                        </td>
                                        <td align="center">
                                            @if (ViewData["SupplierList"] != null)
                                            {
                                                if (item.z_status == "T")
                                                {
                                                    @Html.DropDownListFor(m => m.theQuotes[item.quote_seq].supplier_id, new SelectList((IEnumerable<SelectListItem>)ViewData["SupplierList"], "Value", "Text", item.supplier_id), new { onchange = $"OnSupplierChanged({item.quote_seq});", @class = "form-control", style = "display: none; font-size: 14px; min-width: 200px; max-width: 200px;" });
                                                }
                                                else
                                                {
                                                    @Html.DropDownListFor(m => m.theQuotes[item.quote_seq].supplier_id, new SelectList((IEnumerable<SelectListItem>)ViewData["SupplierList"], "Value", "Text", item.supplier_id), new { onchange = $"OnSupplierChanged({item.quote_seq});", @class = "form-control", style = "display: initial; font-size: 14px; min-width: 200px; max-width: 200px;" });
                                                }
                                            }
                                            @if (item.z_status == "T")
                                            {
                                                @Html.TextBox($"theQuotes[{item.quote_seq}].supplier_name", item.supplier_name, new { @type = "text", @class = "form-control", style="font-size: 14px; min-width: 220px; max-width: 220px; display: initial;" })
                                            }
                                            else
                                            {
                                                @Html.TextBox($"theQuotes[{item.quote_seq}].supplier_name", item.supplier_name, new { @type = "text", @class = "form-control", style="font-size: 14px; min-width: 220px; max-width: 220px; display: none;" })
                                            }
                                            <input type="hidden" id="theQuotes_@(item.quote_seq)__supplier_country" name="theQuotes[@item.quote_seq].supplier_country" value="@item.supplier_country">
                                            <input type="text" id="theQuotes_@(item.quote_seq)__show_country" value="@item.supplier_country" readonly class="hideBorder" style="text-align: center; font-size: medium; min-width: 35px; max-width: 35px; display: @(item.z_status == "T" ? "none" : "initial");" />
                                        </td>
                                        <td align="center">
                                            <select id="theQuotes_@(item.quote_seq)__vendor_id" name="theQuotes[@item.quote_seq].vendor_id" @(item.z_status == "T" ? "disabled" : "") onchange="changeVendor(@item.quote_seq);" class="form-control" style="display: inline; min-width: 240px; max-width: 240px; font-size: 14px;"></select>
                                            <input type="hidden" id="theQuotes_@(item.quote_seq)__vendor_name" name="theQuotes[@item.quote_seq].vendor_name" value="@item.vendor_name">
                                        </td>
                                        <td align="center">
                                            <input type="hidden" id="theQuotes_@(item.quote_seq)__price_usd" name="theQuotes[@item.quote_seq].price_usd" value="@item.price_usd">
                                            @Html.TextBox($"theQuotes[{item.quote_seq}].unit_price", item.unit_price, new { @type = "number", @step = ".0001", @autocomplete = "off", required = "required", @onfocusout = $"priceDiff({item.quote_seq});", @class = "form-control", style="text-align: right; font-size: medium; min-width: 100px; max-width: 100px;" })
                                        </td>
                                        <td align="center">
                                            <input type="hidden" id="theQuotes_@(item.quote_seq)__currency_rate" name="theQuotes[@item.quote_seq].currency_rate" value="@item.currency_rate">
                                            @Html.DropDownListFor(m => m.theQuotes[item.quote_seq].currency_id, new SelectList((IEnumerable<SelectListItem>)ViewData["CurrencyList"], "Value", "Text"), new { @class = "form-control", onchange = $"priceDiff({item.quote_seq});", style="font-size: medium; min-width: 85px; max-width: 85px;" })
                                        </td>
                                        <td align="center">
                                            @Html.TextBox($"theQuotes[{item.quote_seq}].price_diff", item.price_diff, new { @type = "number", @step = ".01", @class = "hideBorder", style="text-align: right; font-size: medium; min-width: 75px; max-width: 75px;" })
                                        </td>
                                        <td align="center">
                                            @Html.TextBox($"theQuotes[{item.quote_seq}].tariff", item.tariff, new { @type = "number", @step = ".01", @autocomplete = "off", @onfocusout = $"priceAllIn({item.quote_seq});", @class = "form-control", style="text-align: right; font-size: medium; min-width: 75px; max-width: 75px;" })
                                        </td>
                                        <td align="center">
                                            @Html.TextBox($"theQuotes[{item.quote_seq}].price_all_in", item.price_all_in, new { @type = "number", @step = ".0001", @class = "hideBorder", style="text-align: right; font-size: medium; min-width: 75px; max-width: 75px;" })
                                        </td>
                                        <td align="center">
                                            @Html.TextBox($"theQuotes[{item.quote_seq}].moq", item.moq, new { @type = "number", @autocomplete = "off", @class = "form-control", style="text-align: right; font-size: medium; min-width: 75px; max-width: 75px;" })
                                        </td>
                                        <td align="center">
                                            @Html.TextBox($"theQuotes[{item.quote_seq}].lead", item.lead, new { @type = "text", @autocomplete = "off", @class = "form-control", style="font-size: medium; min-width: 120px; max-width: 120px;" })
                                        </td>
                                        <td align="center">
                                            @Html.TextBox($"theQuotes[{item.quote_seq}].supplier_info", item.supplier_info, new { @type = "text", @autocomplete = "off", @class = "form-control", style="font-size: 14px; min-width: 265px; max-width: 265px;" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- #endregion -->
    </div>
</form>
@*}*@




<script type="text/javascript">
    var module = @Html.Raw(Json.Encode(@Model));
    //var quotesCount = module.theQuotes.length;
    var PreloadList = @Html.Raw(Json.Encode(@ViewData["PreloadList_SO"]));
    var SupplierList = @Html.Raw(Json.Encode(@ViewData["SupplierList"]));
    var cluster = '@ViewBag.cluster';
    var EnableRequired = ('@ViewData["EnableRequired"]' === 'True');
    var LatestExchangeRate = @Html.Raw(Json.Encode(ViewData["LatestExchangeRate"]));


    function PrepareForPage() {
        let j = 0;
        
        if (cluster != "FTB") {
            document.getElementById('sourcing').checked = false;
            if (module.sourcing === 'Y')
                document.getElementById('sourcing').checked = true;
            if (module.cluster === 'Domestic')
                document.getElementById('urgent').checked = module.urgent;
        }

        if (PreloadList != null)
        {
            if (document.getElementById('preload_so').selectedIndex <= 0)
                document.getElementById('preload_so').selectedIndex = 1;
        }
        
        //alert(quotesCount);
        for (j = 1; j < module.theQuotes.length; j++) {
            //alert("j: " + j);
            //alert(module.theQuotes[j].z_status);
            document.getElementById("theQuotes_" + j + "__z_status").value = module.theQuotes[j].z_status;
            if (module.theQuotes[j].z_status === 'T') {
                CheckApprove(j);
            }

            OnSupplierChanged(j);
            //priceDiff(j);
        }
        
        //alert(EnableRequired);
        if (EnableRequired) {
            document.getElementById("new_quantity").setAttribute("required", "");
            if (cluster == "FTB") {
                document.getElementById("theFTB_sourced_by").setAttribute("required", "");
                document.getElementById("theFTB_pod_no").setAttribute("required", "");
                document.getElementById("theFTB_buyer").setAttribute("required", "");
                document.getElementById("theFTB_customer_provide_sample").setAttribute("required", "");
            }
        }

        //alert('Prepare Okay');
    }


    function onChangeBuyToLoc() {
        document.getElementById("po_to_loc").value = document.getElementById("buy_to_loc").value;
    }


    function priceDiff(theNo) {
        let currency = document.getElementById('theQuotes_' + theNo + '__currency_id').value;
        @*let theExchangeRate = parseFloat('@decimal.Parse(ViewData["LatestExchangeRate"].ToString())');*@
        let theExchangeRate = LatestExchangeRate.find(f => f.currency_id == currency).exchange_rate;
        //alert(theNo + '\r\n' + currency + '\r\n' + theExchangeRate);
        document.getElementById('theQuotes_' + theNo + '__currency_rate').value = theExchangeRate;
        let new_price = document.getElementById('theQuotes_' + theNo + '__unit_price').value;

        //alert(new_price);
        if (currency == 1) {
            document.getElementById('theQuotes_' + theNo + '__price_usd').value = new_price;
        }
        else {
            document.getElementById('theQuotes_' + theNo + '__price_usd').value = (new_price / theExchangeRate).toFixed(4);
        }
        //alert(document.getElementById('theQuotes_' + theNo + '__price_usd').value);

        if (cluster === "FTB")
            document.getElementById('theQuotes_' + theNo + '__price_diff').value = 0;
        else {
            new_price = document.getElementById('theQuotes_' + theNo + '__price_usd').value;
            let last_price = document.getElementById('last_price').value;
            let diff = (((parseFloat(new_price) / parseFloat(last_price)) - 1) * 100).toFixed(2);
            //alert(theNo + '\r\n' + last_price + '\r\n' + new_price + '\r\n' + diff);
            document.getElementById('theQuotes_' + theNo + '__price_diff').value = diff;
            if (diff <= 100) {
                document.getElementById('theQuotes_' + theNo + '__price_diff').style.color = 'green';
            }
            else {
                document.getElementById('theQuotes_' + theNo + '__price_diff').style.color = 'red';
            }
            //alert('priceDiff okay.');
        }

        priceAllIn(theNo);

        if (cluster == "FTB" && theNo == 1) {
            grand_total();
        }
    }


    function priceAllIn(theNo) {
        let price_usd = parseFloat(document.getElementById('theQuotes_' + theNo + '__price_usd').value);
        //alert(price_usd);
        let tariff = parseFloat(document.getElementById('theQuotes_' + theNo + '__tariff').value);
        //alert(tariff);
        if (price_usd > 0) {
            document.getElementById('theQuotes_' + theNo + '__price_all_in').value = (price_usd * (1+tariff/100)).toFixed(4);
        }
        //alert(document.getElementById('theQuotes_' + theNo + '__price_all_in').value);
    }


    function total() {
        let qty = document.getElementById('new_quantity').value;

        let weight = document.getElementById('unit_weight').value;
        let totweight = (((parseFloat(weight) * parseFloat(qty))) * 0.453592).toFixed(2);
        document.getElementById('total_weight').value = totweight;

        //EA= 1
        //C = 100
        let last_price = 0;
        if (cluster == "FTB") {
            last_price = document.getElementById('supplier_standard_cost').value; //EA
            let currency = document.getElementById('primary_supplier_currency').value;
            let theExchangeRate = LatestExchangeRate.find(f => f.currency_id == currency).exchange_rate;
            last_price = last_price / theExchangeRate;
        }
        else {
            last_price = document.getElementById('last_price').value; //OS: C, Domestic: EA
        }
        //let totvalue = ((parseFloat(qty) * parseFloat(last_price)) / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        let totvalue = parseFloat(qty) * parseFloat(last_price);
        if (cluster == "OS")
            totvalue = totvalue / 100;
        //totvalue = totvalue.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        //document.getElementById('total_value').value = totvalue;
        document.getElementById('total_value').value = totvalue.toLocaleString(undefined, { maximumFractionDigits: 2 });

        //alert(last_price + '\r\n' + qty + '\r\n' + weight + '\r\n' + totvalue + '\r\n' + totweight);
        document.getElementById('PO_order_quantity_1').value = document.getElementById('new_quantity').value;
        grand_total();
    }


    function grand_total() {
        if (cluster == "FTB") {
            //C = 100
            //EA= 1
            let qty = document.getElementById('PO_order_quantity_1').value;
            let unit_price = document.getElementById('theQuotes_1__unit_price').value;
            let totvalue = parseFloat(qty) * parseFloat(unit_price) / 100;
            totvalue = totvalue + +document.getElementById('theFTB_ppap_cost').value;
            totvalue = totvalue + +document.getElementById('theFTB_tc_cost').value;

            let quoteCount = document.getElementsByClassName("quotes").length;
            let currency = document.getElementById('primary_supplier_currency').value;
            for (let i = 1; i < quoteCount; i++) {
                if (document.getElementById('theQuotes_' + i + '__z_status').value === 'A')
                    currency = document.getElementById('theQuotes_' + i + '__currency_id').value;
            }

            let theExchangeRate = LatestExchangeRate.find(f => f.currency_id == currency).exchange_rate;
            totvalue = totvalue / theExchangeRate;

            //totvalue = totvalue.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
            //document.getElementById('grand_total_value').value = totvalue;
            document.getElementById('grand_total_value').value = totvalue.toLocaleString(undefined, { maximumFractionDigits: 2 });
        }
        //alert(document.getElementById('grand_total_value').value);
    }


    function CheckApprove(theNo) {
        let id = 0;
        let approve = '';

        let combolBox = document.getElementById("theQuotes_"+theNo+"__z_status");
        if (combolBox.options[combolBox.selectedIndex].value === 'T') {
            document.getElementById('theQuotes_'+theNo+'__supplier_id').style.display = 'none';
            document.getElementById('theQuotes_'+theNo+'__show_country').style.display = 'none';
            document.getElementById('theQuotes_'+theNo+'__supplier_name').style.display = 'initial';
            document.getElementById('theQuotes_'+theNo+'__vendor_id').options.length = 0;
            document.getElementById("theQuotes_"+theNo+"__vendor_id").setAttribute("disabled", true);
            document.getElementById('theQuotes_'+theNo+'__vendor_name').value = "";
        }
        else {
            document.getElementById('theQuotes_'+theNo+'__supplier_id').style.display = 'initial';
            document.getElementById('theQuotes_'+theNo+'__show_country').style.display = 'initial';
            document.getElementById('theQuotes_'+theNo+'__supplier_name').style.display = 'none';
            document.getElementById("theQuotes_"+theNo+"__vendor_id").removeAttribute("disabled");
        }

        let chkBox = document.getElementById('Quotations').querySelectorAll('.detailSelect');
        for (let j = 1; j < chkBox.length; j++) {
            if (document.getElementById("theQuotes_"+theNo+"__z_status").selectedIndex === 1) {   //This one is Approved
                if (j != theNo && chkBox[j].options[chkBox[j].selectedIndex].value != 'T' ) {
                    chkBox[j].selectedIndex = 0;    //Candidate
                }
            }

            if (chkBox[j].options[chkBox[j].selectedIndex].value === 'A') {
                let supplier = document.getElementById('theQuotes_'+j+'__supplier_id')
                id = supplier.options[supplier.selectedIndex].value;
                approve = supplier.options[supplier.selectedIndex].text;
            }
        }

        document.getElementById('vendor_id').value = id;
        document.getElementById('vendor_approve').value = approve;
        //alert(theNo + ' Check Okay.');
    }


    function changeVendor(theNo) {
        let vendorSelection = document.getElementById('theQuotes_'+theNo+'__vendor_id')
        document.getElementById('theQuotes_'+theNo+'__vendor_name').value = vendorSelection.options[vendorSelection.selectedIndex].text;
    }


    function AppendFunc() {        
        let newIndex = parseInt(document.getElementById('QuoteCount').value);
        let afterIndex = newIndex - 1;
        //alert(newIndex);

        let newTR = document.createElement('tr');
        let theHTML = document.getElementById("Quote_0").innerHTML;
        theHTML = theHTML.replaceAll("Quote_0", `Quote_${newIndex}`);
        theHTML = theHTML.replaceAll("theQuotes[0]", `theQuotes[${newIndex}]`);
        theHTML = theHTML.replaceAll("theQuotes_0_", `theQuotes_${newIndex}_`);
        theHTML = theHTML.replaceAll("herf_0", `herf_${newIndex}`);
        theHTML = theHTML.replaceAll("priceDiff(0)", `priceDiff(${newIndex})`);
        theHTML = theHTML.replaceAll("priceAllIn(0)", `priceAllIn(${newIndex})`);
        theHTML = theHTML.replaceAll("CheckApprove(0)", `CheckApprove(${newIndex})`);
        theHTML = theHTML.replaceAll("OnSupplierChanged(0)", `OnSupplierChanged(${newIndex})`);
        theHTML = theHTML.replaceAll("changeVendor(0)", `changeVendor(${newIndex})`);
        theHTML = theHTML.replaceAll("RemoveFunc(0)", `RemoveFunc(${newIndex})`);

        //alert(theHTML);
        newTR.innerHTML = theHTML;
        newTR.style.display = 'table-row';
        newTR.id = "Quote_" + newIndex;

        let ele = document.getElementById("Quote_" + afterIndex);
        ele.after(newTR);
        document.getElementById("theQuotes_" + newIndex + "__quote_seq").value = newIndex.toString();
        document.getElementById("herf_" + newIndex).removeAttribute("disabled");
        document.getElementById('QuoteCount').value = (newIndex + 1).toString();
        
        let chkBox = document.getElementById("theQuotes_" + newIndex + "__currency_id");
        chkBox.selectedIndex = 0;
        if (cluster === 'OS') 
            chkBox.value = 6;

        let previousHerf = document.getElementById("herf_" + afterIndex);
        if (previousHerf != null)
            previousHerf.setAttribute("disabled", true);

        //alert('OkayAppend');
    } 


    function RemoveFunc(theNo) {
        document.getElementById("Quote_" + theNo).remove(); 

        document.getElementById('QuoteCount').value = document.getElementById('QuoteCount').value - 1;
        let afterIndex = document.getElementById('QuoteCount').value - 1;
        let previousHerf = document.getElementById("herf_" + afterIndex);
        if (previousHerf != null)
            previousHerf.removeAttribute("disabled");
    } 
    

    function OnSupplierChanged(theNo) {
        //alert('onchange');
        FetchVendorList(theNo);
        FetchSupplierInfo(theNo);
        
        //alert(theNo);
        let supplier = document.getElementById('theQuotes_'+theNo+'__supplier_id')
        //alert(supplier.selectedIndex);
        //alert(supplier.options[supplier.selectedIndex].text);
        document.getElementById("theQuotes_"+theNo+"__supplier_name").value = supplier.options[supplier.selectedIndex].text;
        //alert('ok');
    }


    function FetchVendorList(theNo) {
        //alert("theNo: " + theNo);
        let supplier_id = parseInt($("#theQuotes_" + theNo + "__supplier_id").val());
        let company_id = $("#company_id").val();
        let items = '';
        var vendorJsonData;
        //alert('supplier_id: ' + supplier_id + '\r\n' + 'company_id: ' + company_id);

        $("#theQuotes_"+theNo+"__vendor_id").prop("disabled", true);
        $("#theQuotes_"+theNo+"__vendor_id").empty();
        if (supplier_id > 0) {
            //alert(theNo + " call");
            $.when(ajax_call(supplier_id, company_id))
                .done(function () {
                    //alert(theNo + ' Done');
                    if (vendorJsonData == null) {
                        alert("Error returned vendor data from quote " + theNo + ".");
                    } else {
                        $(vendorJsonData).each(function () {
                            items += "<option value='" + this.vendor_id + "'>" + this.vendor_name + " [" + this.terms_desc + "]</option>";
                        });
                        //alert(items);
                        $("#theQuotes_" + theNo + "__vendor_id").html(items);
                        //alert($("#theQuotes_" + theNo + "__vendor_id option").length);

                        let selection = document.getElementById("theQuotes_" + theNo + "__vendor_id");
                        if (selection.length >= 1) {
                            $("#theQuotes_"+theNo+"__vendor_id").val(supplier_id);
                            document.getElementById('theQuotes_'+theNo+'__vendor_name').value = selection.options[selection.selectedIndex].text;
                        } 
                        //alert('Vendor ok');
                    }

                    //alert(theNo + ' Supplier changed');
                })
                .fail(function() {
                    alert("Couldn't find the vendor data for quote " + theNo + ".");
                })
            ;
        }
        $("#theQuotes_"+theNo+"__vendor_id").prop("disabled", false);

        function ajax_call(supplier_id, company_id) {
            //alert(supplier_id + '\r\n' + company_id);
            return $.ajax({
                    cache: false,
                    url: '@Url.Action("GetVendorList", "Procurement")',
                    data: { "supplier_id": supplier_id, "company_id": company_id },
                    type: "GET",
                    contentType: "application/json; charset=utf-8",
                    datatype: JSON,
                    success: function (result) {
                        vendorJsonData = result;
                    }
            });
        }
    }


    function FetchSupplierInfo(theNo) {
        //alert(cluster);
        $("#theQuotes_"+theNo+"__show_country").prop("disabled", true);
        let supplier_id = $("#theQuotes_"+theNo+"__supplier_id").val();
        let ItemID = $("#ItemID").val();
        let po_to_loc = $("#po_to_loc").val();
        $.ajax({
            cache: false,
            url: '@Url.Action("GetSupplierInfo", "Procurement")',
            data: { "location_id": po_to_loc, "item_id": ItemID, "supplier_id": supplier_id },
            type: "GET",
            contentType: "application/json; charset=utf-8",
            datatype: JSON,
            success: function (result) {
                //alert(result.supplier_part_no);
                $("#theQuotes_"+theNo+"__supplier_country").val(result.phys_country);
                $("#theQuotes_"+theNo+"__show_country").val(result.phys_country);
                $("#theQuotes_" + theNo + "__show_country").prop("disabled", false);
                
                $("#theQuotes_"+theNo+"__currency_id").val(result.currency_id);
                
                //alert(supplier_id + '\r\n' + module.primary_supplier_id)
                if (cluster == "Domestic") {
                    if (Model.primary_supplier_id == supplier_id) {
                        $("#theQuotes_"+theNo+"__unit_price").prop("disabled", true);
                        $("#theQuotes_"+theNo+"__unit_price").val(result.cost);
                        $("#theQuotes_" + theNo + "__unit_price").prop("disabled", false);
                    }
                    $("#theQuotes_"+theNo+"__supplier_info").prop("disabled", true);
                    $("#theQuotes_"+theNo+"__supplier_info").val(result.supplier_part_no);
                    $("#theQuotes_"+theNo+"__supplier_info").prop("disabled", false);
                }
                //alert('SupplierInfo ok');
            }
        });
    }


    function onRequiredDateChange() {
        //document.getElementById("ship_out_date").valueAsDate = document.getElementById("required_date").valueAsDate;
        document.getElementById("expected_date").valueAsDate = document.getElementById("required_date").valueAsDate;
    }


    function onCheckSourcing() {
        if (document.getElementById('chk_sourcing').checked)
            document.getElementById('sourcing').value = 'Y';
        else
            document.getElementById('sourcing').value = '';
        //alert(document.getElementById('sourcing').value);
        
        if (document.getElementById('chk_sourcing_in').checked)
            document.getElementById('sourcing_in').value = 'Y';
        else
            document.getElementById('sourcing_in').value = '';
        
        if (document.getElementById('chk_sourcing_vn').checked)
            document.getElementById('sourcing_vn').value = 'Y';
        else
            document.getElementById('sourcing_vn').value = '';
    }


    function onCheckUrgent() {
        if (document.getElementById('chk_urgent').checked)
            document.getElementById('urgent').value = 'true';
        else
            document.getElementById('urgent').value = 'false';
        //alert(document.getElementById('sourcing').value);
    }


    function onChangePPAP() {
        let combolBox = document.getElementById("theFTB_ppap_level");
        if (combolBox.options[combolBox.selectedIndex].value != '') {
            document.getElementById("theFTB_ppap_cost").removeAttribute("disabled");
            document.getElementById("theFTB_ppap_cost").setAttribute("required", "");
            document.getElementById("theFTB_ppap_note").removeAttribute("disabled");
        }
        else {
            document.getElementById("theFTB_ppap_cost").setAttribute("disabled", true);
            document.getElementById("theFTB_ppap_cost").removeAttribute("required");
            document.getElementById("theFTB_ppap_note").setAttribute("disabled", true);
        }
    }


    function onCheckTC() {
        if (document.getElementById('theFTB_tc').checked) {
            document.getElementById("theFTB_tc_cost").removeAttribute("disabled");
            document.getElementById("theFTB_tc_cost").setAttribute("required", "");
            document.getElementById("theFTB_tc_note").removeAttribute("disabled");
        }
        else {
            document.getElementById("theFTB_tc_cost").setAttribute("disabled", true);
            document.getElementById("theFTB_tc_cost").removeAttribute("required");
            document.getElementById("theFTB_tc_note").setAttribute("disabled", true);
        }
    }


    function onCheckDrawing() {
        if (document.getElementById('theFTB_drawing').checked) {
            document.getElementById("theFTB_print_no").setAttribute("required", "");
            document.getElementById("theFTB_print_no").removeAttribute("disabled");
            document.getElementById("theFTB_rev_no").setAttribute("required", "");
            document.getElementById("theFTB_rev_no").removeAttribute("disabled");
        }
        else {
            document.getElementById("theFTB_print_no").removeAttribute("required");
            document.getElementById("theFTB_print_no").setAttribute("disabled", true);
            document.getElementById("theFTB_rev_no").removeAttribute("required");
            document.getElementById("theFTB_rev_no").setAttribute("disabled", true);
        }
    }


    function onChangeSample(selectObject) {
        //alert(selectObject.value);
        if (selectObject.value === 'True') {
            document.getElementById("theFTB_sample_tracking_number").removeAttribute("disabled");
            document.getElementById("theFTB_sample_tracking_number").setAttribute("required", "");
        }
        else {
            document.getElementById("theFTB_sample_tracking_number").setAttribute("disabled", true);
            document.getElementById("theFTB_sample_tracking_number").removeAttribute("required");
        }
    }


    window.addEventListener("load", PrepareForPage);
</script>


@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

