                    </div>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.MOQSupplierLoc1, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7 display">
                            @Html.ValueFor(model => model.MOQSupplierLoc1)
                        </div>
                    </div>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.LeadTime, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7 display">
                            @Html.ValueFor(model => model.LeadTime)
                        </div>
                    </div>
                </div>
                <!-- #endregion -->
                    
                <!-- #region Documents -->
                @if (ViewBag.cluster == "FTB")
                {
                    <br>
                    <div class="card">
                        <h3 style="text-align: center;">Documents</h3>

                        @{ 
                            if (Model.theFTB.theDocuments != null && Model.theFTB.theDocuments.Count() > 0) 
                            { 
                                int i = 0;
                                foreach (var doc in Model.theFTB.theDocuments)
                                {
                                    <div class="form-group perline">
                                        <input type="hidden" name="theFTB.theDocuments[@i].link_name" value="@doc.link_name">
                                        <input type="hidden" name="theFTB.theDocuments[@i].link_path" value="@doc.link_path">
                                        <input type="hidden" name="theFTB.theDocuments[@i].folder_path" value="@doc.folder_path">
                                        <input type="hidden" name="theFTB.theDocuments[@i].file_name" value="@doc.file_name">
                                        <input type="hidden" name="theFTB.theDocuments[@i].date_last_modified" value="@doc.date_last_modified">
                                        <input type="hidden" name="theFTB.theDocuments[@i].last_maintained_by" value="@doc.last_maintained_by">

                                        <label class="control-label col-md-5">@doc.link_name</label>
                                        <div class="col-md-7 display word-wrap">
                                            @Html.ActionLink(doc.file_name, "DownloadDocument", "Procurement", new { pm_folder = HttpUtility.UrlEncode(doc.folder_path), pm_file_name = HttpUtility.UrlEncode(doc.file_name) }, new { target = "_blank", title = "Last modified on " + doc.date_last_modified.ToString("yyyy/MM/dd HH:mm") + " by " + doc.last_maintained_by })
                                        </div>
                                    </div>
                                    i++;
                                }
                            }
                        }
                    </div>
                }
                <!-- #endregion -->
            </div>

            <div class="column" style="width: 22%;">
