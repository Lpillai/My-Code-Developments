                    {
                        <input type="hidden" id="preload_quantity" name="preload_quantity" value="@Model.preload_quantity" />
                        <input type="hidden" id="preload_loc" name="preload_loc" value="@Model.preload_loc" />
                        <input type="hidden" id="package" name="package" value="@Model.package" />
                    }
                    else
                    {
                        if (ViewBag.cluster == "FTB")
                        {
                            <div class="form-group perline">
                                @Html.LabelFor(model => model.theFTB.ship_method, htmlAttributes: new { @class = "control-label col-md-5" })
                                <div class="col-md-7">
                                    @Html.DropDownList("theFTB.ship_method", (IEnumerable<SelectListItem>)ViewData["List_ShipMethod"], new { id = "theFTB_ship_method", @class = "form-control col-md-2 input-sm", style = "font-size: medium;" })
                                </div>
                            </div>
                        }

                        <div class="form-group perline">
                            @Html.LabelFor(model => model.preload_quantity, htmlAttributes: new { @class = "control-label col-md-5" })
                            <div class="col-md-7">
                                <input type="number" name="preload_quantity" value="@Model.preload_quantity" autocomplete="off" onclick="$(this).select();" class="form-control input-sm" style="font-size: medium;" />
                            </div>
                        </div>

                        <div class="form-group perline">
                            @Html.LabelFor(model => model.preload_loc, htmlAttributes: new { @class = "control-label col-md-5" })
                            <div class="col-md-7">
                                @if (ViewData["List_preload_loc"] == null)
                                {
                                    <input type="text" name="preload_loc" value="@Model.preload_loc" autocomplete="off" class="form-control col-md-2 input-sm" style="font-size: medium;" />
                                }
                                else
                                {
                                    @Html.DropDownList("preload_loc", (SelectList)ViewData["List_preload_loc"], new { id = "preload_loc", @class = "form-control col-md-2 input-sm", style = "font-size: medium;" })
                                }
                            </div>
                        </div>

                        <div class="form-group perline">
                            @Html.LabelFor(model => model.package, htmlAttributes: new { @class = "control-label col-md-5" })
                            <div class="col-md-7">
                                <input type="text" name="package" value="@Model.package" autocomplete="off" class="form-control input-sm" style="font-size: medium;" />
                            </div>
                        </div>
                    }

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.total_value, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7">
                            @Html.TextBox("total_value", Model.total_value, new { @readonly = "readonly", @class = "hideBorder", style = "min-width: 120px; max-width: 120px; font-size: medium;" })
                        </div>
                    </div>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.total_weight, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7">
                            @Html.TextBox("total_weight", Model.total_weight, new { @readonly = "readonly", @class = "hideBorder", style = "min-width: 120px; max-width: 120px; font-size: medium;" })
                        </div>
                    </div>
                </div>
                <!-- #endregion -->
                
                <!-- #region Other Charges -->
                @if (ViewBag.cluster == "FTB")
                {
                    <br>
                    <div class="card">
                        <h3 style="text-align: center; margin-bottom: 10px;">Other Charges</h3>
                        
                        <div class="form-group perline">
                            @Html.LabelFor(model => model.theFTB.ppap_level, htmlAttributes: new { @class = "control-label col-md-5" })
                            <div class="col-md-7">
                                @Html.DropDownListFor(m => m.theFTB.ppap_level, new SelectList((IEnumerable<SelectListItem>)ViewData["List_PPAP"], "Value", "Text", Model.theFTB.ppap_level), new { onchange = "onChangePPAP();", @class = "form-control col-md-2 input-sm", style = "font-size: medium;" })
                            </div>
                        </div>
                                                    
                        <div class="form-group perline">
                            @Html.LabelFor(model => model.theFTB.ppap_cost, htmlAttributes: new { @class = "control-label col-md-5" })
                            <div class="col-md-7">
                                <input type="number" id="theFTB_ppap_cost" name="theFTB.ppap_cost" value="@Model.theFTB.ppap_cost" autocomplete="off" @(string.IsNullOrWhiteSpace(Model.theFTB.ppap_level) ? "disabled" : "") @(string.IsNullOrWhiteSpace(Model.theFTB.ppap_level) ? "" : "required") onclick="$(this).select();" onfocusout="grand_total();" class="form-control input-sm" style="font-size: medium;" />
                                @Html.ValidationMessageFor(model => model.theFTB.ppap_cost, "", new { @class = "text-danger" })
                            </div>
                        </div>
                            
                        <div class="form-group perline">
