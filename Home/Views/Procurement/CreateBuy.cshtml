                {
                    if (ViewBag.cluster == "Domestic")
                    {
                        @Html.ActionLink("Archive", "RunArchive", new { cluster = ViewBag.cluster, pm_ItemID = Model.ItemID }, new { target = "_blank" })
                    } else { 
                        @Html.ActionLink("Archive", "BuyArchiveItem", new { item_id = Model.ItemID }, new { target = "_blank" })
                    }
                }
                @Html.EditorFor(model => model.ItemID, new { htmlAttributes = new { required = "required", @class = "form-control", style = "font-size: medium;" } })
                @Html.ValidationMessageFor(model => model.ItemID, "", new { @class = "text-danger" })
            </div>
            <div class="form-group col-md-1" style="text-align:center;">
                <label class="control-label" style="color: transparent">PartInfo</label><br>
                <input type="submit" name="CreateBuyAction:PartInfo" value="Part Info" class="btn btn-default" />
                @*<input type="submit" name="pm_action" value="GetPartInfo" class="btn btn-default" />*@
            </div>
            <div class="form-group col-md-1">
                @Html.HiddenFor(model => model.urgent)
                @Html.HiddenFor(model => model.sourcing)
                @Html.HiddenFor(model => model.sourcing_in)
                @Html.HiddenFor(model => model.sourcing_vn)
            </div>
            <div class="form-group col-md-1">
                <label class="control-label" style="color: transparent">isUrgent</label>
