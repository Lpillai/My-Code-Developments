                    <input type="hidden" name="standard_cost_current" value="@Model.standard_cost_current">
                    <input type="hidden" name="program" value="@Model.program">
                    <input type="hidden" name="standard_cost" value="@Model.standard_cost">
                    <input type="hidden" id="unit_weight" name="unit_weight" value="@Model.unit_weight">
                    <input type="hidden" name="primary_supplier_id" value="@Model.primary_supplier_id">
                    <input type="hidden" id="primary_supplier_currency" name="primary_supplier_currency" value="@Model.primary_supplier_currency">
