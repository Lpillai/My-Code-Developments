                            @Html.ValueFor(model => model.PPAP)
                        </div>
                    </div>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.standard_cost_current, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7 display">
                            @Html.ValueFor(model => model.standard_cost_current)
                        </div>
                    </div>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.program, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7 display">
