                    </div>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.loc_primary_supplier_name, htmlAttributes: new { @class = "control-label col-md-5" })
                        <div class="col-md-7 display" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" data-toggle="tooltip" data-placement="right" title="@Html.DisplayFor(model => model.loc_primary_supplier_name)">
                            @Html.ValueFor(model => model.loc_primary_supplier_name)
                        </div>
                    </div>

                    <div class="form-group perline">
                        @Html.LabelFor(model => model.supplier_standard_cost, htmlAttributes: new { @class = "control-label col-md-5" })
