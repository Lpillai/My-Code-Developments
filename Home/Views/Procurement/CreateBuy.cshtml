@using RuntimeVariables;
@model Buy
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "["+ViewBag.cluster+"] " + ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = "["+ViewBag.cluster+"]" + ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;

    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->




<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: Arial, Helvetica, sans-serif;
    }

    /* Float four columns side by side */
    .column {
        float: left;
        /*width: 30%;*/
        padding: 0 10px;
    }

    /* Remove extra left and right margins, due to padding */
    .row {
        margin: 0 -5px;
    }

        /* Clear floats after the columns */
        .row:after {
            content: "";
            display: table;
            clear: both;
        }

    /* Style the counter cards */
    .card {
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
        padding: 2px 16px 16px 16px;
        text-align: left;
        background-color: #f1f1f1;
    }

    div.perline {
        margin-bottom: 5px;
        display: flex;
        align-items: center;
    }

    div.chk {
        margin-top: -20px;
    }

    div.show {
        padding-top: 7px;
    }

    div.display {
        font-size: medium;
        padding-top: 6px;
    }

    div.quotesHeader {
        text-align: center;
        font-size: 14px;
        font-weight: 600;
    }

    .hideBorder {
        border: 0px none transparent;
        background-color: transparent;
        outline: none;
        padding: 7px 0 0 0;
        /*width: 60px;*/
    }

    textarea {
        padding: 10px;
        max-width: 100%;
        line-height: 1.5;
        border-radius: 5px;
        border: 1px solid #ccc;
        box-shadow: 1px 1px 1px #999;
    }


    a[disabled] {
        pointer-events: none;
        cursor: default;
    }
</style>




<h4>@ViewBag.Path</h4>


@if (ViewBag.cluster != "FTB")
{
    <div>
        <a href="#myModal" class="btn" data-toggle="modal">Upload</a>
        @*@Ajax.ActionLink("Download example sheet", "ExampleSheet", "Procurement", null, null, null)*@
        @Html.ActionLink("Download example sheet", "ExampleSheet", "Procurement", null, new { @target = "_blank" })
    </div>
}


<div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            @using (Html.BeginForm("UploadFile", "Procurement", new { cluster = @ViewBag.cluster }, FormMethod.Post, new { id = "form_upload", enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&Chi;</span>
                    </button>
                    <h4 class="modal-title" id="myModalLabel">Upload Excel</h4>
                </div>
                <div class="modal-body">
                    @Html.TextBox("pm_file", "", new { type = "file", id = "filepath", accept = ".xls, .xlsx" })
                </div>
                <div class="modal-footer">
                    <input type="submit" id="btn_upload" value="Upload" class="btn btn-primary" @attr_html />
                </div>
            }
        </div>
    </div>
</div>




@*@using (Html.BeginForm("goBuyCreateAction", "Procurement", FormMethod.Post))
{*@
<form action="" method="post">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.cluster)

    <div class="form-horizontal">
        
        <!-- #region Buttons -->
        <div class="row" style="margin: 0px;">
