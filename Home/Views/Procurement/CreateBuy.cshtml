                    <label class="control-label" style="color: transparent">Sourcing VN</label>
                    <br>
                    <div class="col-md-1" style="padding: 3px 0 0 0;">
                        <input type="checkbox" id="chk_sourcing_vn" value="" onclick="javascript:onCheckSourcing();" style="height: 20px;" />
                    </div>
                    @Html.LabelFor(model => model.sourcing_vn, htmlAttributes: new { @class = "control-label col-md-11" })
                </div>
            }
            <div class="form-group col-md-1" style="text-align:right;">
                <label class="control-label" style="color: transparent">Create</label>
                <br>
                <input type="submit" name="CreateBuyAction:Create" value="Create" class="btn btn-primary" onclick="return confirm('Create this buy?');" @attr_html />
                @*<input type="submit" name="pm_action" value="CreateOne" class="btn btn-primary" onclick="return confirm('Create this buy?');" @attr_html />*@
            </div>
        </div>
        <div class="form-group" style="margin-bottom: 0px;">
            @Html.LabelFor(model => model.item_desc, htmlAttributes: new { @class = "control-label col-md-1" })
            <div class="col-md-11 show">
                @Html.ValueFor(model => model.item_desc)
            </div>
        </div>
        <div class="form-group" style="margin-bottom: 0px;">
            @Html.LabelFor(model => model.extended_desc, htmlAttributes: new { @class = "control-label col-md-1" })
            <div class="col-md-11 show">
                @Html.ValueFor(model => model.extended_desc)
            </div>
        </div>
        <!-- #endregion -->
        
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="row">
            <div class="column" style="width: 28%;">
                <!-- #region Part Info -->
