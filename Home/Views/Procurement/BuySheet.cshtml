<script type='text/javascript'>
    function yesnoCheck() {
        if (document.getElementById('yesCheck').checked) {
            document.getElementById('ifYes').style.display = 'table-cell';
            document.getElementById('theSheet').style.width = 'calc(100vw - 300px)';
        }
        else {
            document.getElementById('ifYes').style.display = 'none';
            document.getElementById('theSheet').style.width = 'calc(100vw - 30px)';
        }
    }


    function ScrollPosition() {
        var divElement = document.getElementById('toUpdate');
        divElement.scroll({
            top: divElement.scrollHeight,//scroll to bottom of the element
            //top: 0,//scroll to top of the element
            behavior: 'smooth' //auto, smooth, initial, inherit
        });
    }


    function getOne(theNo) {
        //alert(theNo);
        var moduleList = @Html.Raw(Json.Encode(@Model));
        //alert(moduleList[theNo - 1].entryID);
        document.getElementById('pm_newNote_entryID').value = moduleList[theNo - 1].entryID;
        document.getElementById('pm_newNote_viewID').value = moduleList[theNo - 1].viewID;

        if (!document.getElementById('yesCheck').checked) {
            document.getElementById('yesCheck').checked = true;
            document.getElementById('ifYes').style.display = 'table-cell';
            document.getElementById('theSheet').style.width = 'calc(100vw - 300px)';
        }
    }


    function resetNewNoteBox() {
        document.getElementById('pm_newNote_Text').value = "";
    }


    function applyPO() {
        var cnt = 0;
        var CData = new Array();
        var selectElement = document.getElementsByClassName("detailSelect");
        var moduleList = @Html.Raw(Json.Encode(@Model));

        for (var i = 0; i < selectElement.length; i++) {
            if (selectElement[i].checked) {
                cnt = cnt + 1;
                CData.push(moduleList[i].entryID);
            }
        }

        //alert(cnt.toString() + "\r\n" + CData.toString());
        document.getElementById('collection_Count').innerHTML = cnt.toString();
        document.getElementById('collection_entryID').value = JSON.stringify(CData);
    }


    function validateApply(form) {
        if (document.getElementById('collection_Count').innerHTML == "0") {
            alert('Please select at least one buy before applying.');
            return false;
        }
        if (document.getElementById('pmNewPO').value == "" || document.getElementById('pmNewVendor').value == "") {
            alert('Please fill up both PO and vendor columns.');
            return false;
        }
    }


    function cancelSelected() {
        var select = true;

        var cnt = 0;
        var selectElement = document.getElementsByClassName("detailSelect");
        for (var i = 0; i < selectElement.length; i++) {
            if (selectElement[i].checked)
                cnt = cnt + 1;
        }

        if (cnt > 0)
            select = false;

        for (var i = 0; i < selectElement.length; i++) {
            selectElement[i].checked = select;
        }
    }


    function onSelect(form) {
        var cnt = 0;
        var CData = new Array();
        var selectElement = document.getElementsByClassName("detailSelect");
        var moduleList = @Html.Raw(Json.Encode(@Model));

        for (var i = 0; i < selectElement.length; i++) {
            if (selectElement[i].checked) {
                cnt = cnt + 1;
                CData.push(moduleList[i].viewID);
            }
        }

        //alert(cnt.toString() + "\r\n" + CData.toString());
        document.getElementById('collection_viewID').value = JSON.stringify(CData);
        document.getElementById('collection_selectedCount').value = cnt;

        if (cnt === 0) {
            alert('No records selected.');
            return false;
        }
    }
</script>


<script type="text/javascript">
    var filterList = @Html.Raw(Json.Encode(@ViewBag.Filters));
    for (var i = 0; i < filterList.length; i++) {
        if (filterList[i].op != '' && filterList[i].op !== null) {
            //alert(filterList[i].op);
            var hdr = 'th_' + filterList[i].key;
            document.getElementById(hdr).className = 'filtered';
            //alert(filterList[i].key);
        }
    }
</script>



