@using RuntimeVariables;
@model IEnumerable<Buy>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;
    ViewBag.Source = "BuySheet";


    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->




<h4>
    @ViewBag.Path
</h4>




<div class="modal fade" id="applyModal" tabindex="-1" role="dialog" aria-labelledby="applyModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            @using (Html.BeginForm("ApplyPOAsync", "Procurement", new { cluster = @ViewBag.cluster }, FormMethod.Post, new { enctype = "multipart/form-data", onsubmit = "return validateApply(this);" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&Chi;</span>
                    </button>
                    <h4 class="modal-title" id="applyModalLabel">Apply PO number</h4>
                </div>
                <div class="modal-body">
                    <label id="collection_Count" name="collection_Count" style="font-size:large; font-style:normal; margin-left:10px; margin-top:-25px; margin-bottom:20px;">0</label>&nbsp;&nbsp;records selected.
                    <input type="hidden" id="collection_entryID" name="collection_entryID">
                    <br>
                    <input id="pmNewPO" name="pmNewPO" type="text" placeholder="PO Number" class="form-control" />
                </div>
                <div class="modal-footer">
                    <input type="submit" class="btn btn-primary" value="Apply" @attr_html onclick="return confirm('It will take a few seconds to process. Apply PO for selected buys?');" />
                </div>
            }
        </div>
    </div>
</div>


