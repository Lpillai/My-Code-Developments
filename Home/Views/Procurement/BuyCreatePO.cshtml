@using RuntimeVariables;
@model IEnumerable<BuySheet_CreatePO>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Create New PO";
    ViewBag.PageName = "[" + ViewBag.cluster + "] " + " Create New Purchase Order";


    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}

@helper SayHello(Buy wkBuy)
{
    BuyQuote theApproved = (wkBuy.theQuotes == null ? null : wkBuy.theQuotes.First(f => f.z_status == "A"));
    string supplier = "";
    string new_price_ntd = "";
    string new_price_usd = "";
    string Lead = "";
    string Price_Diff = "";

    if (theApproved != null)
    {
        supplier = theApproved.supplier_id.ToString();
        new_price_ntd = (theApproved.currency_id == 1 ? "" : theApproved.unit_price.ToString());
        new_price_usd = theApproved.price_usd.ToString();
        Lead = (string.IsNullOrWhiteSpace(theApproved.lead) ? "" : theApproved.lead);
        Price_Diff = theApproved.price_diff.ToString();
    }

    <td class="display" align="right">
        @Html.Raw(new_price_ntd)
    </td>
    <td class="display" align="right">
        @Html.Raw(new_price_usd)
    </td>
    <td class="display" align="center">
        @Html.Raw(Lead)
    </td>
    <td class="display" align="right">
        @Html.Raw(Price_Diff)
    </td>
}




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->




<style>
    body {
        font-family: Arial, Helvetica, sans-serif;
    }

    .column {
        float: left;
        width: 100%;
        padding: 0 10px;
        margin: 5px 0 8px 0;
    }

    .card {
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
        padding: 16px 16px 0 16px;
        text-align: left;
        background-color: #f1f1f1;
    }



    table {
        border-collapse: collapse;
        width: 100%;
    }

    td, th {
        padding: 6px 4px 0 4px; /*
        border: 1px solid black;
        border-collapse: collapse;*/
    }

        td.display {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .table-hover tbody tr:hover td,
    .table-hover tbody tr:hover th {
        background-color: rgb(255 205 143 / 0.2);
    }

    /* Set a fixed scrollable wrapper */
    .tableScroll {
        width: 100%;
        overflow-x: scroll;
        display: inline-block;
    }



    .distinct {
        background-color: powderblue;
    }
</style>




<script type="text/javascript">
    function CheckBeforeSubmit() {
        if (confirm('It will take a few seconds to process. Create PO for these buys?') == false)
            return false;
        
        document.getElementById('btnSubmit').setAttribute('disabled', 'disabled');
        document.getElementById('btnSubmit').value = "Processing...";
        document.getElementById('CreateForm').submit();
        return true;
    }
</script>




<h4>@ViewBag.PageName</h4>




@using (Html.BeginForm("GoCreatePOAsync", "Procurement", new { cluster = ViewBag.cluster }, FormMethod.Post, new { id = "CreateForm", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div style="margin-bottom: 10px;">
        <div class="col-md-9">
            @Html.ActionLink("Back to List", "BuySheet", "Procurement", new { cluster = ViewBag.cluster }, new { @class = "btn" })
        </div>
        <div class="col-md-3">
            <input type="submit" id="btnSubmit" value="Create @ViewBag.createCount PO" class="btn btn-primary btn-large" @(ViewBag.createCount > 0 ? "" : "disabled") onclick="return CheckBeforeSubmit();" @attr_html />
        </div>
    </div>

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    {
        var index = 0;

        foreach (var PO in Model)
        {
            <div class="column">
                <div class="card">
                    <div class="form-group">
                        <div class="col-md-1 @(PO.go == "True" ? "distinct" : "")" style="text-align: center;">
                            @Html.DisplayNameFor(model => model.go)
                        </div>
                        <div class="col-md-2 @(PO.go == "True" ? "distinct" : "")" style="text-align: right;">
                            @Html.DisplayNameFor(model => model.vendor_approve)
                        </div>
                        <div class="col-md-9 @(PO.go == "True" ? "distinct" : "")" style="color: orangered;">
                            @Html.Raw("　")
                            @Html.DisplayFor(POItem => PO.vendor_approve)
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-1 @(PO.go == "True" ? "distinct" : "")" style="text-align: center; font-weight: bold; color: @(PO.go == "True" ? "black" : "orangered");">
                            @Html.DisplayFor(POItem => PO.go)
                        </div>
                        <div class="col-md-2 @(PO.go == "True" ? "distinct" : "")" style="text-align: right;">
                            @Html.DisplayNameFor(model => model.po_to_loc)
                        </div>
                        <div class="col-md-9 @(PO.go == "True" ? "distinct" : "")" style="color: orangered;">
                            @Html.Raw("　")
                            @Html.DisplayFor(POItem => PO.po_to_loc)
                        </div>
                    </div>
                    <div id="myDIV_@PO.no" class="form-group tableScroll">
                        <table class="table table-sm table-hover" style="table-layout: fixed;">
                            @*<colgroup>
                                <col id="col_01" style="width: 40px;">
                                <col id="col_02" style="width: 68px;">
                                <col id="col_03" style="width: 56px;">
                                <col id="col_04" style="width: 180px;">
                                <col id="col_05" style="width: 280px;">
                                @if (ViewBag.cluster != "Domestic")
                                {
                                    <col id="col_06" style="width: 80px;">
                                }
                                <col id="col_07" style="width: 120px;">
                                <col id="col_08" style="width: 120px;">
                                <col id="col_09" style="width: 120px;">
                                <col id="col_10" style="width: 80px;">
                                <col id="col_11" style="width: 100px;">
                                <col id="col_12" style="width: 160px;">
                                <col id="col_14" style="width: 80px;">
                                <col id="col_15" style="width: 80px;">
                                <col id="col_16" style="width: 120px;">
                                <col id="col_17" style="width: 90px;">
                            </colgroup>*@
                            <thead>
                                <tr>
                                    <th style="text-align:center;">
                                        @Html.DisplayNameFor(model => model.POLine[0].no)
                                    </th>
                                    <th style="text-align:center;">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.viewID)
                                    </th>
                                    <th style="text-align: center;">
                                        @Html.DisplayNameFor(model => model.POLine[0].status)
                                    </th>
                                    <th style="padding-left: 20px;">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.ItemID)
                                    </th>
                                    <th style="padding-left: 20px;">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.item_desc)
                                    </th>
                                    @if (ViewBag.cluster != "Domestic")
                                    {
                                        <th style="text-align:center">
                                            @Html.DisplayNameFor(model => model.POLine[0].BuySheet.package)
                                        </th>
                                    }
                                    <th style="text-align:center">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.new_quantity)
                                    </th>
                                    <th style="text-align:center">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.PO_order_quantity_1)
                                    </th>
                                    <th style="text-align:center">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.required_date)
                                    </th>
                                    <th style="text-align:center">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.PPAP)
                                    </th>
                                    <th style="text-align:center">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.program)
                                    </th>
                                    <th style="text-align:center">
                                        @Html.DisplayNameFor(model => model.POLine[0].BuySheet.TruePrimarySupplier)
                                    </th>
                                    <th style="text-align:center">
                                        @Html.Raw("Unit Price (C)")
                                    </th>
                                    <th style="text-align:center">
                                        @if (ViewBag.cluster == "Domestic")
                                        {
                                            @Html.Raw("USD/EA")
                                        }
                                        else
                                        {
                                            @Html.Raw("USD/C")
                                        }
                                    </th>
                                    <th style="text-align:center">
                                        @Html.Raw("Lead Time")
                                    </th>
                                    <th style="text-align:center">
                                        @Html.Raw("Price Diff")
                                    </th>
                                </tr>
                            <thead>
                            <tbody>
                                @foreach (var item in PO.POLine)
                                {
                                    <tr>
                                        <td class="display" align="center" style="padding-right: 5px;">
                                            @Html.Hidden($"pm_Sheet[{index}].GroupNo", PO.no)
                                            @Html.DisplayFor(modelItem => item.no)
                                        </td>
                                        <th class="display" scope="row" style="text-align: center;">
                                            @Html.Hidden($"pm_Sheet[{index}].viewID", item.BuySheet.viewID)
                                            @Html.DisplayFor(modelItem => item.BuySheet.viewID)
                                        </th>
                                        <th class="display" style="text-align: center;">
                                            @Html.DisplayFor(modelItem => item.status)
                                        </th>
                                        <td class="display">
                                            @Html.DisplayFor(modelItem => item.BuySheet.ItemID)
                                        </td>
                                        <td class="display" data-toggle="tooltip" data-placement="right" title="@Html.DisplayFor(modelItem => item.BuySheet.item_desc)">
                                            @Html.DisplayFor(modelItem => item.BuySheet.item_desc)
                                        </td>
                                        @if (ViewBag.cluster != "Domestic")
                                        {
                                            <td class="display">
                                                @Html.DisplayFor(modelItem => item.BuySheet.package)
                                            </td>
                                        }
                                        <td class="display" style="text-align: right; padding-right: 15px; padding-left: 10px;">
                                            @Html.DisplayFor(modelItem => item.BuySheet.new_quantity)
                                        </td>
                                        <td class="display" style="text-align: right; padding-right: 15px; padding-left: 10px;">
                                            @Html.DisplayFor(modelItem => item.BuySheet.PO_order_quantity_1)
                                        </td>
                                        <td class="display" align="center">
                                            @Html.ValueFor(modelItem => item.BuySheet.required_date, "{0:MM/dd/yyyy}")
                                        </td>
                                        <td class="display">
                                            @Html.DisplayFor(modelItem => item.BuySheet.PPAP)
                                        </td>
                                        <td class="display">
                                            @Html.DisplayFor(modelItem => item.BuySheet.program)
                                        </td>
                                        <td class="display" data-toggle="tooltip" data-placement="right" title="@Html.DisplayFor(modelItem => item.BuySheet.TruePrimarySupplier)">
                                            @Html.DisplayFor(modelItem => item.BuySheet.TruePrimarySupplier)
                                        </td>

                                        @SayHello(item.BuySheet)
                                    </tr>
                                    if (item.BuyRelease.Count() > 0)
                                    {
                                        <tr>
                                            @if (ViewBag.cluster != "Domestic")
                                            {
                                                <td colspan="6">&nbsp;</td>
                                            }
                                            else 
                                            { 
                                                <td colspan="5">&nbsp;</td>
                                            }
                                            <td colspan="3">
                                                <table class="table table-sm" style="table-layout: fixed; margin-bottom: 15px; background-color: transparent;">
                                                    @*<colgroup>
                                                        <col id="emcol_01" style="width: 120px;">
                                                        <col id="emcol_02" style="width: 120px;">
                                                        <col id="emcol_03" style="width: 120px;">
                                                    </colgroup>*@
                                                    <thead>
                                                        <tr>
                                                            <th colspan="3" style="text-align: center; padding: 0;">
                                                                @Html.Raw("Release Line")
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var sub in item.BuyRelease)
                                                        {
                                                            <tr class="table-active">
                                                                <td style="text-align: right; padding: 0 15px 0 10px;">
                                                                    @Html.DisplayFor(subItem => sub.quantity)
                                                                </td>
                                                                <td style="text-align: right; padding: 0 15px 0 10px;">
                                                                    @Html.DisplayFor(subItem => sub.po_quantity)
                                                                </td>
                                                                <td style="text-align: center; padding: 0;">
                                                                    @Html.DisplayFor(subItem => sub.release_date)
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </td>
                                            <td colspan="7">
                                                &nbsp;
                                            </td>
                                        </tr>
                                    }

                                    index++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
}

<br>
