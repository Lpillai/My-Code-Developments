@model IEnumerable<RuntimeVariables.BuyQuote>



<h4 style="text-align: center;">
    Quotation of @ViewData["viewID"]
</h4>

<div style="margin-top: 20px;">
    <table class="table table-sm table-hover align-middle">
        <thead>
            <tr>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.quote_seq)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.z_status)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.supplier_name)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.vendor_name)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.unit_price)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.currency_name)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.price_all_in)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.moq)
                </th>
                <th style="text-align: center;">
                    @Html.DisplayNameFor(model => model.lead)
                </th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || Model.Count() == 0)
            {
                <tr>
                    <td colspan="9" style="text-align:center;"> No data dound. </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td style="text-align: right; font-size: medium; padding-right: 5px;">
                            @Html.DisplayFor(modelItem => item.quote_seq)
                        </td>
                        <td style="text-align: center; font-size: medium;">
                            @Html.DisplayFor(modelItem => item.z_status)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.supplier_name)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.vendor_name)
                        </td>
                        <td style="text-align: right; font-size: medium; padding-right: 20px;">
                            @Html.DisplayFor(modelItem => item.unit_price)
                        </td>
                        <td style="text-align: center; font-size: medium;">
                            @Html.DisplayFor(modelItem => item.currency_name)
                        </td>
                        <td style="text-align: right; font-size: medium; padding-right: 20px;">
                            @Html.DisplayFor(modelItem => item.price_all_in)
                        </td>
                        <td style="text-align: right; font-size: medium;">
                            @Html.DisplayFor(modelItem => item.moq)
                        </td>
                        <td style="text-align: right; font-size: medium;">
                            @Html.DisplayFor(modelItem => item.lead)
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

