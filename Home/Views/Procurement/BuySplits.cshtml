@model IEnumerable<RuntimeVariables.BuySplit>



<h4 style="text-align: center;">
    Splits of @ViewData["viewID"]
    @if (ViewBag.Source == "BuySheet" && (bool)ViewData["isEditable"])
    {
        <span>&nbsp; &nbsp;</span>
        @Html.ActionLink("Update", "EditSplits", new { cluster = ViewBag.cluster, pm_split_entryID = ViewData["entryID"], pm_split_viewID = ViewData["viewID"] }, new { @class = "ui-btn" })
    }
</h4>

<div style="margin-top: 20px;">
    <table class="table table-sm table-hover align-middle">
        <tr>
            @if (ViewBag.cluster == "FTB")
            { 
                <th style="text-align: center; font-size: 14px; width: 100px; max-width: 100px;">
                    @Html.DisplayNameFor(model => model.ship_method)
                </th>
            }
            <th style="text-align: center; font-size: 14px; width: 120px; max-width: 120px; ">
                @Html.DisplayNameFor(model => model.release_date)
            </th>
            <th style="text-align: center; font-size: 14px; width: 120px; max-width: 120px; ">
                @Html.DisplayNameFor(model => model.quantity)
            </th>
            <th style="text-align: center; font-size: 14px; width: 120px; max-width: 120px; ">
                @Html.DisplayNameFor(model => model.expected_date)
            </th>
            <th style="text-align: center; font-size: 14px; width: 120px; max-width: 120px; ">
                @Html.DisplayNameFor(model => model.po_quantity)
            </th>
            <th style="text-align: center; font-size: 14px;">
                @Html.DisplayNameFor(model => model.preload_po_so)
            </th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                @if (ViewBag.cluster == "FTB")
                { 
                    <td style="text-align: center; font-size: medium;">
                        @Html.DisplayFor(modelItem => item.ship_method)
                    </td>
                }
                <td style="text-align: center; font-size: medium;">
                    @Html.DisplayFor(modelItem => item.release_date)
                </td>
                <td style="text-align: right; font-size: medium; padding-right: 20px;">
                    @Html.DisplayFor(modelItem => item.quantity)
                </td>
                <td style="text-align: center; font-size: medium;">
                    @Html.DisplayFor(modelItem => item.expected_date)
                </td>
                <td style="text-align: right; font-size: medium; padding-right: 20px;">
                    @Html.DisplayFor(modelItem => item.po_quantity)
                </td>
                <td style="text-align: center; font-size: medium;">
                    @Html.DisplayFor(modelItem => item.preload_po_so)
                </td>
            </tr>
        }
        @if (Model.Count() > 0)
        {
            <tr>
                <th @(ViewBag.cluster == "FTB" ? "colspan=2" : "") style="text-align: center; font-size: medium;">
                    Subtotal
                </th>
                <td style="text-align: right; font-size: medium; padding-right: 20px;">
                    @Html.DisplayFor(modelItem => @Model.First().sumQuant)
                </td>
                <td>
                    &nbsp;
                </td>
                <td style="text-align: right; font-size: medium; padding-right: 20px;">
                    @Html.DisplayFor(modelItem => @Model.First().po_sumQuant)
                </td>
                <td>
                    &nbsp;
                </td>
            </tr>
        }
    </table>
</div>

