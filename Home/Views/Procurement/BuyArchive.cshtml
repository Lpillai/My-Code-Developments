@using RuntimeVariables;
@model IEnumerable<Buy>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;
    ViewBag.Source = "BuyArchive";
}




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->




@if ((bool)ViewBag.takeSession)
{
    <h4>
        @ViewBag.Path
    </h4>
}
else
{
    <h4>
        @ViewBag.PageName
    </h4>
}



<div class="modal fade" id="splitsModal" tabindex="-1" role="dialog" aria-labelledby="splitsModalLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="mySplits" style="padding: 10px 50px 10px 50px;">
        </div>
    </div>
</div>


<div class="modal fade" id="filtersModal" tabindex="-1" role="dialog" aria-labelledby="filtersModalLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="myFilters">
        </div>
    </div>
</div>





<style>
    table.detailed {
        border-spacing: 20px 1px;
        border-collapse: separate;
    }

    .action_btn {
        font-size: 15px;
    }

    /* Set a fixed scrollable wrapper */
    .tableScroll {
        height: calc(100vh - 150px);
        width: calc(100vw - 30px);
        overflow: auto;
        display: inline-block;
    }

    .noteScrollY {
        display: none;
        width: 265px;
        vertical-align: top;
        overflow-x: hidden;
        padding: 0 0 0 5px;
    }

    .noteList {
        width: 100%;
        height: calc(100vh - 150px);
        overflow-x: hidden;
    }

    textarea {
        padding: 10px;
        max-width: 100%;
        line-height: 1.5;
        border-radius: 5px;
        border: 1px solid #ccc;
        box-shadow: 1px 1px 1px #999;
    }

    /* ------------------------------------------------------------------------------------------------------------------------------------ */

    thead th {
        position: sticky;
        top: 0;
        background-color: #eee;
        z-index: 1;
    }

        thead th:nth-child(3) {
            left: 0;
            z-index: 3;
        }

        thead th:nth-child(4) {
            left: 60px;
            z-index: 3;
        }

    tbody th:nth-child(3) {
        position: sticky;
        left: 0;
        z-index: 2;
        background-color: white;
        box-shadow: 1px 0 0 0 #ccc;
    }

    tbody th:nth-child(4) {
        position: sticky;
        left: 60px;
        z-index: 2;
        background-color: white;
        box-shadow: 1px 0 0 0 #ccc;
    }

    /* ------------------------------------------------------------------------------------------------------------------------------------ */

    table {
        border-collapse: collapse;
    }
/*
    td, th {
        padding: 6px 2px 0 2px; 
        border: 1px solid black;
        border-collapse: collapse;
    }
*/
    .table-hover tbody tr:hover td,
    .table-hover tbody tr:hover th {
        background-color: rgb(255 205 143 / 0.2);
    }

    td.display {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>




<script type='text/javascript'>
    function yesnoCheck() {
        if (document.getElementById('yesCheck').checked) {
            document.getElementById('ifYes').style.display = 'table-cell';
            document.getElementById('theSheet').style.width = 'calc(100vw - 300px)';
        }
        else {
            document.getElementById('ifYes').style.display = 'none';
            document.getElementById('theSheet').style.width = 'calc(100vw - 30px)';
        }
    }


    function ScrollPosition() {
        var divElement = document.getElementById('toUpdate');
        divElement.scroll({
            top: divElement.scrollHeight,//scroll to bottom of the element
            //top: 0,//scroll to top of the element
            behavior: 'smooth' //auto, smooth, initial, inherit
        });
    }


    function getOne(theNo) {
        if (!document.getElementById('yesCheck').checked) {
            document.getElementById('yesCheck').checked = true;
            document.getElementById('ifYes').style.display = 'table-cell';
            document.getElementById('theSheet').style.width = 'calc(100vw - 300px)';
        }
    }
</script>




