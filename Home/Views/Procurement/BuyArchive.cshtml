                            @Html.ValueFor(modelItem => item.expected_date, "{0:MM/dd/yyyy}")
                        </td>
                        @if (ViewBag.cluster != "Domestic")
                        {
                            <td class="display" data-toggle="tooltip" data-placement="right" title="@Html.DisplayFor(modelItem => item.preload_PO_SO)">
                                @Html.DisplayFor(modelItem => item.preload_PO_SO)
                            </td>
                        }
                        @if (ViewBag.cluster == "Domestic")
                        {
                            <td align="center">
                                @Html.DisplayFor(modelItem => item.urgent)
                            </td>
                        }
                        @if (ViewBag.cluster != "FTB")
                        {
                            <td align="center">
                                @Html.DisplayFor(modelItem => item.creator)
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.Count() <= 0)
        {
            <div style="font-size: larger; text-align: center; color: darkorange;">No data from querying. Please use Filters to get what you need.</div>
        }
    </div>

    <div id="ifYes" class="noteScrollY">
        <div class="noteList">
            <div id="toUpdate"></div>
        </div>
    </div>
</div>


@if (Model.Count() >= 200)
{
    <script type="text/javascript">
        alert('This querying only returned the latest 200 records. Please specify more filter conditions if you could not find what you want in these records.');
    </script>
}


@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

