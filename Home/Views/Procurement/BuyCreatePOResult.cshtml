                    </div>
                    <div class="col-md-2 @((ViewData["ResultList"] as List<cmd_Result>)[PO.no-1].Succeeded == 1 ? "distinct" : "")" style="text-align: right; font-weight: bold;">
                        @Html.DisplayNameFor(model => model.vendor_approve)
