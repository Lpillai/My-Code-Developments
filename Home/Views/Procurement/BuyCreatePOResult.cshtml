                    <div class="col-md-11 @((ViewData["ResultList"] as List<cmd_Result>)[PO.no-1].Succeeded == 1 ? "distinct" : "")" style="font-weight: @((ViewData["ResultList"] as List<cmd_Result>)[PO.no-1].Succeeded == 1 ? "Bold" : "Normal"); color: @((ViewData["ResultList"] as List<cmd_Result>)[PO.no-1].Succeeded == 1 ? "black" : "orangered");">
