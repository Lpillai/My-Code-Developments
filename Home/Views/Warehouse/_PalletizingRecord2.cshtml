                                                            @Html.TextBox($"pm_lines[{i}].same_box_no", bin.same_box_no.ToString("0;;' '"), new { @type = "number", @placeholder = "SB", @autocomplete = "off", @onfocus = "this.select()", @class = "col-xs-1", style = "padding: 0 2px; text-align: right;" })
                                                        </div>
