                        <div class="row" style="font-weight: 600; padding: 3px; border-bottom: 1px solid lightsteelblue;">
                            <div class="col-xs-1" style="text-align: center;">
                                @Html.DisplayNameFor(model => model.line_number)
                            </div>
                            <div class="col-xs-5" style="text-align: center;">
                                @Html.DisplayNameFor(model => model.item_id)
                            </div>
                            <div class="col-xs-2" style="text-align: center;">
                                @Html.DisplayNameFor(model => model.print_quantity)
                            </div>
                            <div class="col-xs-2" style="text-align: center;">
                                @Html.DisplayNameFor(model => model.packing_person)
                            </div>
                            <div class="col-xs-2" style="text-align: center;">
                                &nbsp;
                            </div>
                        </div>
                        <div class="row" style="font-weight: 600; padding: 3px;">
                            <div class="col-xs-2" style="text-align: center;">
                                &nbsp;
                            </div>
                            <div class="col-xs-2" style="text-align: center;">
                                @Html.DisplayNameFor(model => model.bins[0].lot_cd)
                            </div>
                            <div class="col-xs-2" style="text-align: center;">
                                @Html.DisplayNameFor(model => model.bins[0].bin_id)
                            </div>
                            <div class="col-xs-2" style="text-align: center;">
                                @Html.DisplayNameFor(model => model.bins[0].qty_allocated_delta)
                            </div>
                            <div class="col-xs-4" style="padding-left: 5px;">
                                @Html.Raw("Difference")
                            </div>
                        </div>
                    </th>
                </tr>
            </thead>
            <tbody>
                @{ 
                    if (Model == null || Model.Count() <= 0)
                    {
                        <tr>
                            <td style="text-align: center;">No lines found.</td>
                        </tr>
                    }
                    else
                    {
                        int k = 0; 
                        foreach (var line in Model)
                        {
                            <tr>
                                <td>
                                    <div class="row">
                                        @using (Html.BeginForm("GoUpdate_Palletizing", "Warehouse", FormMethod.Post, new { enctype = "multipart/form-data" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("pm_pick_ticket_no", ViewData["pick_ticket_no"], null)
                                    
                                            <div class="form-group" style="font-weight: 600; margin: 0;">
                                                <div class="col-xs-1">
                                                    @Html.DisplayFor(l => line.line_number)
                                                </div>
                                                <div class="col-xs-5">
                                                    @Html.DisplayFor(l => line.item_id)
                                                </div>
                                                <div class="col-xs-2" style="text-align: right;">
                                                    @Html.DisplayFor(l => line.print_quantity)
                                                </div>
                                                <div class="col-xs-2">
                                                    @Html.DisplayFor(l => line.packing_person)
                                                </div>
                                                <div class="col-xs-2" style="text-align: right;">
                                                    @Html.Hidden("rows_count_" + k.ToString(), line.bins.Count(), null)
                                                    @*<input type="submit" value="&#128427;" class="btn btn-primary" style="padding: 2px 4px 0 4px; border-radius: 4px; font-size: larger;" @attr_html onclick="return confirm('Update this line?');" />*@
                                                    <input type="submit" value="Save" class="btn btn-primary" style="padding: 2px 3px 0 3px; border-radius: 4px; font-size: small;" @attr_html onclick="return confirm('Update this line?');" />
                                                </div>
                                            </div>

                                            if (line.bins == null || line.bins.Count() <= 0)
                                            {
                                                <div class="form-group" style="color: green; text-align:center;">No lots or bins found.</div>
                                            }
                                            else
                                            {
                                                int i = 0;
                                                int palletizing_count = 0;
                                                foreach (var bin in line.bins)
                                                {
                                                    if (bin.palletizing_no > 0)
                                                    {
                                                        palletizing_count = 0;
                                                        <div class="form-group col-xs-12" style="color: green; margin: 6px 0 0 0;">
                                                            <div class="col-xs-2">
                                                                @Html.Hidden("newHerfStack_" + k.ToString() + "_" + bin.line_seq.ToString(), "["+string.Join(",", line.bins.Where(b => b.line_seq == bin.line_seq).Select(a => "\"herf_"+k.ToString()+"_"+(a.bin_seq > 0 ? a.bin_seq-1 : a.bin_seq).ToString()+"\""))+"]", null)
                                                                @Html.Hidden("newDivStack_" + k.ToString() + "_" + bin.line_seq.ToString(), "["+string.Join(",", line.bins.Where(b => b.line_seq == bin.line_seq).Select(a => "\"line_detail_"+k.ToString()+"_"+(a.bin_seq > 0 ? a.bin_seq-1 : a.bin_seq).ToString()+"\""))+"]", null)
                                                            </div>
                                                            <div class="col-xs-2">
                                                                @Html.DisplayFor(l => bin.lot_cd)
                                                            </div>
                                                            <div class="col-xs-2">
                                                                @Html.DisplayFor(l => bin.bin_id)
                                                            </div>
                                                            <div class="col-xs-2" style="text-align: right;">
                                                                @Html.DisplayFor(l => bin.qty_allocated_delta)
                                                            </div>
                                                            <div class="col-xs-1">
                                                                @*<a class="btn" style="padding: 0; margin: 0 10px;" onclick="AppendFunc(@k, @bin.line_seq, @(bin.bin_seq > 0 ? bin.bin_seq-1 : bin.bin_seq))">@("\u271A")</a>*@
                                                                <a class="btn" style="padding: 0; margin: -2px 0 0 0;" onclick="AppendFunc(@k, @bin.line_seq, @(bin.bin_seq > 0 ? bin.bin_seq-1 : bin.bin_seq))">  &#10010;  </a>
                                                            </div>
                                                            <div class="col-xs-3" style="color: red; padding: 0 3px;">
                                                                <input type="text" id="summary_@(k)_@bin.line_seq" value="@(bin.qty_allocated_delta == bin.summary ? "" : (bin.qty_allocated_delta - bin.summary).ToString("N0"))" readonly tabIndex="-1" class="raw" style="text-align: left; padding: 0;" />
                                                            </div>
                                                        </div>
                                                    }
                                                    palletizing_count++;
                                                    <div id="line_detail_@(k)_@(i)">
                                                        <div class="form-group col-xs-12" style="color: lightslategrey; margin: 0px;">
                                                            <div class="col-xs-2" style="text-align: center;">
                                                                @Html.Hidden($"pm_lines[{i}].palletizing_no", bin.palletizing_no, null)
                                                                @Html.Hidden($"pm_lines[{i}].line_number", line.line_number, null)
                                                                @Html.Hidden($"pm_lines[{i}].oe_line_no", line.oe_line_no, null)
                                                                @Html.Hidden($"pm_lines[{i}].inv_mast_uid", line.inv_mast_uid, null)
                                                                @Html.Hidden($"pm_lines[{i}].item_id", line.item_id, null)
                                                                @Html.Hidden($"pm_lines[{i}].customer_part_number", line.customer_part_number, null)
                                                                @Html.Hidden($"pm_lines[{i}].print_quantity", line.print_quantity, null)
                                                                @Html.Hidden($"pm_lines[{i}].packing_person", line.packing_person, null)
                                                                @Html.Hidden($"pm_lines[{i}].line_seq", bin.line_seq, null)
                                                                @Html.Hidden($"pm_lines[{i}].lot_cd", bin.lot_cd, null)
                                                                @Html.Hidden($"pm_lines[{i}].bin_id", bin.bin_id, null)
                                                                @Html.Hidden($"pm_lines[{i}].country_of_origin", bin.country_of_origin, null)
                                                                @Html.Hidden($"pm_lines[{i}].qty_allocated_delta", bin.qty_allocated_delta, null)
                                                                @if (bin.palletizing_no == 0)
                                                                {
                                                                    <a id="herf_@(k)_@(i)" class="btn" @(line.bins.Where(w => w.line_seq == bin.line_seq).Count() == palletizing_count ? "" : "disabled") style="padding: 0; margin: 0;" onclick="RemoveFunc(@k, @bin.line_seq, @(bin.bin_seq > 0 ? bin.bin_seq-1 : bin.bin_seq), @i)">  @("\u2718")  </a>
                                                                }
                                                            </div>
                                                            @*<input type="number" name="qty_per_box" value="@bin.qty_per_box" autocomplete="off" class="col-xs-2" style="padding: 0 2px; text-align: right;" />*@
                                                            @Html.TextBox($"pm_lines[{i}].qty_per_box", bin.qty_per_box.ToString("0;;' '"), new { @type = "number", @id = $"pm_lines_{k}_{i}_qty_per_box", @placeholder = "Qty", @autocomplete = "off", @onfocus = "this.select()", @onchange = $"subtotalize({k}, {bin.line_seq}, {(bin.bin_seq > 0 ? bin.bin_seq-1 : bin.bin_seq)}, {i});", @class = "col-xs-2", style = "padding: 0 2px; text-align: right;" })
                                                            <input type="text" value="x" readonly tabIndex="-1" class="col-xs-1 raw" />
                                                            @Html.TextBox($"pm_lines[{i}].total_boxes", bin.total_boxes.ToString("0;;' '"), new { @type = "number", @id = $"pm_lines_{k}_{i}_total_boxes", @placeholder = "Box", @autocomplete = "off", @onfocus = "this.select()", @onchange = $"subtotalize({k}, {bin.line_seq}, {(bin.bin_seq > 0 ? bin.bin_seq-1 : bin.bin_seq)}, {i});", @class = "col-xs-1", style = "padding: 0 2px; text-align: right;" })
