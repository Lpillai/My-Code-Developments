<script type="text/javascript">
    $(document).ready(function () { 
        document.getElementById('btn_search').removeAttribute("disabled");   
        $("#loading").fadeOut();
    })
</script>
<script type="text/javascript">
    function AppendFunc(line_number, line_seq, bin_seq) {
        //alert(line_number + "\r\n" + line_seq + "\r\n" + bin_seq);
        var newHerfStack = new Array();
        if (document.getElementById('newHerfStack_'+line_number+'_'+line_seq).value != "")
            newHerfStack = JSON.parse(document.getElementById('newHerfStack_'+line_number+'_'+line_seq).value);
        var newDivStack = new Array();
        if (document.getElementById('newDivStack_'+line_number+'_'+line_seq).value != "")
            newDivStack = JSON.parse(document.getElementById('newDivStack_'+line_number+'_'+line_seq).value);
        //alert(newDivStack);

        var lineList = @Html.Raw(Json.Encode(@Model));
        let newIndex = parseInt(document.getElementById('rows_count_' + line_number).value);
        //alert(newIndex);
        const ele = document.getElementById(newDivStack[newDivStack.length-1]);
        const newDiv = document.createElement('div');
        newDiv.innerHTML = `
                <div id="line_detail_${line_number}_${newIndex}" class="form-group col-xs-12" style="color: lightslategrey; margin: 0px;">
                    <div class="col-xs-2" style="text-align: center;">
                        <input id="pm_lines_${newIndex}__palletizing_no" name="pm_lines[${newIndex}].palletizing_no" type="hidden" value="0">
                        <input id="pm_lines_${newIndex}__line_number" name="pm_lines[${newIndex}].line_number" type="hidden" value="${line_number}">
                        <input id="pm_lines_${newIndex}__oe_line_no" name="pm_lines[${newIndex}].oe_line_no" type="hidden" value="${lineList[line_number].oe_line_no}">
                        <input id="pm_lines_${newIndex}__inv_mast_uid" name="pm_lines[${newIndex}].inv_mast_uid" type="hidden" value="${lineList[line_number].inv_mast_uid}">
                        <input id="pm_lines_${newIndex}__item_id" name="pm_lines[${newIndex}].item_id" type="hidden" value="${lineList[line_number].item_id}">
                        <input id="pm_lines_${newIndex}__customer_part_number" name="pm_lines[${newIndex}].customer_part_number" type="hidden" value="${lineList[line_number].customer_part_number}">
                        <input id="pm_lines_${newIndex}__print_quantity" name="pm_lines[${newIndex}].print_quantity" type="hidden" value="${lineList[line_number].print_quantity}">
                        <input id="pm_lines_${newIndex}__packing_person" name="pm_lines[${newIndex}].packing_person" type="hidden" value="${lineList[line_number].packing_person}">
                        <input id="pm_lines_${newIndex}__line_seq" name="pm_lines[${newIndex}].line_seq" type="hidden" value="${line_seq}">
                        <input id="pm_lines_${newIndex}__lot_cd" name="pm_lines[${newIndex}].lot_cd" type="hidden" value="${lineList[line_number].bins[bin_seq].lot_cd}">
                        <input id="pm_lines_${newIndex}__bin_id" name="pm_lines[${newIndex}].bin_id" type="hidden" value="${lineList[line_number].bins[bin_seq].bin_id}">
                        <input id="pm_lines_${newIndex}__country_of_origin" name="pm_lines[${newIndex}].country_of_origin" type="hidden" value="${lineList[line_number].bins[bin_seq].country_of_origin}">
                        <input id="pm_lines_${newIndex}__qty_allocated_delta" name="pm_lines[${newIndex}].qty_allocated_delta" type="hidden" value="${lineList[line_number].bins[bin_seq].qty_allocated_delta}">
                        <a id="herf_${line_number}_${newIndex}" class="btn" style="padding: 0 5px;" onclick="RemoveFunc(${line_number}, ${line_seq}, ${bin_seq}, ${newIndex})">@("\u2718")</a>
                    </div>                      
                    <input type="number" id="pm_lines_${line_number}_${newIndex}_qty_per_box" name="pm_lines[${newIndex}].qty_per_box" value="" placeholder="Qty" onfocus="this.select()" onchange="subtotalize(${line_number},${line_seq},${bin_seq},${newIndex})" autocomplete="off" class="col-xs-2" style="padding: 0 2px; text-align: right;">
                    <input type="text" value="x" readonly tabIndex="-1" class="col-xs-1 raw">
                    <input type="number" id="pm_lines_${line_number}_${newIndex}_total_boxes" name="pm_lines[${newIndex}].total_boxes" value="" placeholder="Box" onfocus="this.select()" onchange="subtotalize(${line_number},${line_seq},${bin_seq},${newIndex})" autocomplete="off" class="col-xs-1" style="padding: 0 2px; text-align: right;">
                    <input type="text" value="=" readonly tabIndex="-1" class="col-xs-1 raw">
                    <input type="text" id="subtotal_${line_number}_${line_seq}_${newIndex}" value="" readonly tabIndex="-1" class="col-xs-2 raw" style="text-align: right; padding-right: 12px;">
                    <input type="number" id="pm_lines_${newIndex}__pallet_no" name="pm_lines[${newIndex}].pallet_no" value="" placeholder="Plt" onfocus="this.select()" autocomplete="off" class="col-xs-1" style="padding: 0 2px; text-align: right; margin-right: 2px;">
                    <input type="number" id="pm_lines_${newIndex}__same_box_no" name="pm_lines[${newIndex}].same_box_no" value="" placeholder="SB" onfocus="this.select()" autocomplete="off" class="col-xs-1" style="padding: 0 2px; text-align: right;">
                </div>
            `;
        ele.after(newDiv);

        document.getElementById('rows_count_' + line_number).value = newIndex + 1;
        newDivStack.push("line_detail_" + line_number + "_" + newIndex);
        document.getElementById('newDivStack_'+line_number+'_'+line_seq).value = JSON.stringify(newDivStack);
        
        var previousHerf = document.getElementById(newHerfStack[newHerfStack.length-1]);
        if (previousHerf != null)
            previousHerf.classList.add("disabled");
        newHerfStack.push("herf_" + line_number + "_" + newIndex);
        document.getElementById('newHerfStack_'+line_number+'_'+line_seq).value = JSON.stringify(newHerfStack);

        //alert('OkayAppend');
    } 


    function RemoveFunc(line_number, line_seq, bin_seq, theIndex) {
        //alert(line_number + "\r\n" + line_seq + "\r\n" + bin_seq + "\r\n" + theIndex);
        var newHerfStack = new Array();
        let theStack = document.getElementById('newHerfStack_' + line_number + '_' + line_seq).value;
        //alert(theStack);
        if (theStack != "") {
            newHerfStack = JSON.parse(theStack);
            newHerfStack.pop();
            if(document.getElementById(newHerfStack[newHerfStack.length-1]) != null)
                document.getElementById(newHerfStack[newHerfStack.length-1]).classList.remove("disabled");
            document.getElementById('newHerfStack_'+line_number+'_'+line_seq).value = JSON.stringify(newHerfStack);
        }
        
        var newDivStack = new Array();
        //alert(document.getElementById('newDivStack_' + line_number + '_' + line_seq).value);
        if (document.getElementById('newDivStack_' + line_number + '_' + line_seq).value != "") {
            newDivStack = JSON.parse(document.getElementById('newDivStack_' + line_number + '_' + line_seq).value);
            newDivStack.pop();
            document.getElementById('newDivStack_'+line_number+'_'+line_seq).value = JSON.stringify(newDivStack);
        }

        $("#line_detail_" + line_number + '_' + theIndex).remove();
        document.getElementById('rows_count_' + line_number).value = parseInt(document.getElementById('rows_count_' + line_number).value) - 1;

        summarize(line_number, line_seq, bin_seq);
        //alert('OkayRemove');
    } 


    function subtotalize(line_number, line_seq, bin_seq, theIndex) {
        //alert(line_number + "\r\n" + line_seq + "\r\n" + bin_seq + "\r\n" + theIndex);

        let qty_per_box = document.getElementById("pm_lines_" + line_number + "_" + theIndex + "_qty_per_box");
        let total_boxes = document.getElementById("pm_lines_" + line_number + "_" + theIndex + "_total_boxes");
        //alert(qty_per_box + "\r\n" + total_boxes);
        if (qty_per_box != null && total_boxes != null && qty_per_box.value != "" && total_boxes.value != "") {
            document.getElementById("subtotal_" + line_number + "_" + line_seq + "_" + theIndex).value = (qty_per_box.value * total_boxes.value).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }
        else {
            document.getElementById("subtotal_" + line_number + "_" + line_seq + "_" + theIndex).value = "";
        }
        
        summarize(line_number, line_seq, bin_seq);
        //alert('OkaySummarize');
    } 


    function summarize(line_number, line_seq, bin_seq) {
        //alert(line_number + "\r\n" + line_seq + "\r\n" + bin_seq);
        
        var lineList = @Html.Raw(Json.Encode(@Model));
        let wk_qty_allocated_delta = lineList[line_number].bins[bin_seq].qty_allocated_delta;
        //alert(wk_qty_allocated_delta);
        let wkSubtotals = 0;
        let indexCount = parseInt(document.getElementById('rows_count_' + line_number).value);
        //alert(indexCount);
        for (let i = 0; i < indexCount; i++) {
            let subtotal = "subtotal_" + line_number + "_" + line_seq + "_" + i;
            let wkElement = document.getElementById(subtotal);
            if (wkElement != null && wkElement.value != "") {
                //alert(i + ": " + subtotal + " is not null.");
                wkSubtotals += parseInt(wkElement.value.replaceAll(',', ''));
                //alert(wkSubtotals);
            }
        }
        //alert(wkSubtotals);
        let wkSummary = wk_qty_allocated_delta - wkSubtotals;
        //alert(wkSummary);
        if (wkSummary == 0) {
            document.getElementById("summary_"+line_number+"_"+line_seq).value = "";
        }
        else {
            document.getElementById("summary_"+line_number+"_"+line_seq).value = wkSummary.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        //alert('OkaySummarize');
    } 
</script>




<div style="width: 100%; display: block; margin-left: auto; margin-right: auto;">
    <div id="theSheet" class="bodyScrollY">
        <table class="table table-hover" style="margin-right: 10px;">
            <thead>
                <tr>
                    @*<th>
                        @Html.DisplayNameFor(model => model.line_number)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.bins[0].qty_per_box)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.bins[0].total_boxes)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.bins[0].pallet_no)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.bins[0].same_box_no)
                    </th>*@
