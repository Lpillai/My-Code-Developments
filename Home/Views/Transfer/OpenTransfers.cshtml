@using RuntimeVariables;
@model IEnumerable<Transfer_PlannedRecptDate>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;

    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}




<style>
    .detailed {
        border: 0px none transparent;
        background-color: transparent;
        outline: none;
        padding: 5px 0 0 0;
        width: 90px;
        text-align: center;
    }

    thead th {
        position: sticky;
        top: 0;
        background: #ffffff;
        z-index: 1;
        text-align: center;
    }

    tbody th {
        position: sticky;
        left: 0;
        z-index: 1;
        background-color: white;
        /* Browsers tend to drop borders on sticky elements, so we emulate the border-right using a box-shadow to ensure it stays: */
        box-shadow: 1px 0 0 0 #ccc;
    }

    .tableScrollY {
        height: calc(100vh - 150px);
        width: 100%;
        overflow: auto;
        display: inline-block;
    }

    td, th {
        padding: 3px;
        /*
        border: 1px solid black;
        border-collapse: collapse;*/
    }

    .table-hover tbody tr:hover td,
    .table-hover tbody tr:hover th {
        background-color: rgb(255 205 143 / 0.2);
    }
</style>




<script type="text/javascript">
    window.onload = function () {
        var today = new Date();
        var dd = today.getDate();
        var mm = today.getMonth() + 1; //January is 0 so need to add 1 to make it 1!
        var yyyy = today.getFullYear();
        if (dd < 10) {
            dd = '0' + dd
        }
        if (mm < 10) {
            mm = '0' + mm
        }
        today = yyyy + '-' + mm + '-' + dd;

        var dateElement = document.getElementById("tbody").querySelectorAll(".dt");
        for (var i = 0; i < dateElement.length; i++) {
            dateElement[i].setAttribute("min", today);
        }
    };
</script>




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->




<h4>@ViewBag.Path</h4>




@using (Html.BeginForm("UpdatePlannedRecptDate", "Transfer", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div style="width: 85%; display: block; margin-left: auto; margin-right: auto;">
        <div style="text-align: right; padding-right: 50px;">
            <input type="submit" value="Save" class="btn btn-primary btn-large" @attr_html />
        </div>
        <div id="theSheet" class="tableScrollY">
            <table class="table table-hover table-striped" style="font-size: medium; table-layout: fixed;">
                <colgroup>
                    @*01*@
                    <col style="width: 20px;">
                    @*02*@
                    <col style="width: 40px;">
                    @*03*@
                    <col style="width: 30px;">
                    @*04*@
                    <col style="width: 30px;">
                    @*05*@
                    <col style="width: 60px;">
                    @*06*@
                    <col style="width: 80px;">
                    @*07*@
                    <col style="width: 60px;">
                    @*08*@
                    <col style="width: 80px;">
                    @*09*@
                    <col style="width: 100px;">
                    @*10*@
                    <col style="width: 40px;">
                    @*11*@
                    <col style="width: 40px;">
                    @*12*@
                    <col style="width: 60px;">
                </colgroup>
                <thead>
                    <tr>
                        <th>
                            @Model.Count().ToString()
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.company_id)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.from_location_id)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.to_location_id)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.transfer_no)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.tracking_no)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.shipping_date)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.planned_recpt_date)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.override_planned_recpt_date)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.days_late)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.items)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.transfer_qty)
                        </th>
                    </tr>
                </thead>

                <tbody id="tbody">
                    @{ var index = 0; }
                    @foreach (var item in Model)
                    {
                        string override_date = item.override_planned_recpt_date.HasValue ? item.override_planned_recpt_date.Value.ToString("yyyy-MM-dd") : "";

                        <tr>
                            <td align="center" style="padding-top: 12px;">
                                @Html.DisplayFor(modelItem => item.no)
                            </td>
                            <td align="center" style="padding-top: 12px;">
                                @Html.ValueFor(modelItem => item.company_id)
                            </td>
                            <td align="center" style="padding-top: 12px;">
                                @Html.ValueFor(modelItem => item.from_location_id)
                            </td>
                            <td align="center" style="padding-top: 12px;">
                                @Html.ValueFor(modelItem => item.to_location_id)
                            </td>
                            <td align="center">
                                @Html.TextBox($"pmShippingTime[{index}].transfer_no", item.transfer_no, new { @readonly = "readonly", @class = "detailed" })
                            </td>
                            <td align="center">
                                <input type="text" name="pmShippingTime[@index].tracking_no" value="@item.tracking_no" autocomplete="off" maxlength="20" class="form-control input-sm dt" style="font-size: medium;">
                            </td>
                            <td align="center" style="padding-top: 12px;">
                                @Html.ValueFor(modelItem => item.shipping_date, "{0:MM/dd/yyyy}")
                            </td>
                            <td align="center" style="padding-top: 12px;">
                                @Html.ValueFor(modelItem => item.planned_recpt_date, "{0:MM/dd/yyyy}")
                            </td>
                            <td align="center">
                                @*<input type="date" name="pmShippingTime[@index].override_planned_recpt_date" value="@item.EDT_override_planned_recpt_date" autocomplete="off" class="form-control input-sm dt" style="font-size: 14px;">*@
                                <input type="date" name="pmShippingTime[@index].override_planned_recpt_date" value="@override_date" autocomplete="off" class="form-control input-sm dt" style="font-size: medium;">
                            </td>
                            <td align="right" style="padding-top: 12px;">
                                @Html.ValueFor(modelItem => item.days_late)
                            </td>
                            <td align="right" style="padding-top: 12px;">
                                @Html.ValueFor(modelItem => item.items)
                            </td>
                            <td align="right" style="padding: 12px 25px 0 0;">
                                @Html.DisplayFor(modelItem => item.transfer_qty)
                            </td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

