<style type="text/css">
</style>




<script type="text/javascript">
    function onEnterPressed(event) {
        if (event.keyCode === 13) {
            goSearch();
        }
    }

    function goSearch() {
        //alert('goSearch');
        document.getElementById('btn_search').setAttribute('disabled', 'disabled');

        $("#loading").fadeIn();
        var target = document.getElementById('loading');
        var spinner = new Spinner(opts).spin(target);
        
        var pmPickTickets = $("#pick_ticket_no").val().replaceAll(" ", "");
        $("#output").load('@Url.Action("show_InternationalShipments", "Transfer")?pmPickTickets=' + pmPickTickets);
    }
</script>
