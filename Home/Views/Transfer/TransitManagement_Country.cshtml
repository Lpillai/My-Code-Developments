@using RuntimeVariables;
@model BuySheet_TransitTime_Country_Method
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;

    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}


@*
@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/jqueryval")
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script src="~/Scripts/jquery-3.4.1.js"></script>
*@




<style>
    .bodyScrollY {
        overflow: auto;
        display: inline-block;
        height: calc(100vh - 235px);
        width: 100%;
    }

    thead tr th {
        position: sticky;
        top: 0;
        background: #ffffff;
        text-align: center;
    }

    .table > tbody > tr > td {
        vertical-align: middle;
    }

    /* ------------------------------------------------------------------------------------------------------------------------------------ */

    /* Float four columns side by side */
    .column {
        float: left;
        width: 49%;
        /*width: 400px;*/
        padding: 0 10px;
    }

    /* Remove extra left and right margins, due to padding */
    .row {
        /*margin: 15px -5px;*/
        margin: 0;
    }
        /* Clear floats after the columns */
        .row:after {
            content: "";
            display: table;
            clear: both;
        }

    .card {
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
        padding: 16px;
        text-align: left;
        background-color: #f1f1f1;
    }
</style>


<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>




<div class="modal fade" id="detailsModal" tabindex="-1" role="dialog" aria-labelledby="detailsModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content" id="myDetails">
        </div>
    </div>
</div>
<div class="modal fade" id="bulkModal" tabindex="-1" role="dialog" aria-labelledby="detailsModalLabel">
    <div class="modal-dialog  modal-lg" role="document">
        <div class="modal-content" id="myBulk">
        </div>
    </div>
</div>





<div class="row" style="padding: 0 10px 10px 15px;">
    @Ajax.ActionLink("Mirror Country Settings", "ShowTransit_CountryMirror", "Transfer", null, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal", @class = "btn btn-default action_btn" })
    @Ajax.ActionLink("Create One Record", "ShowTransit_CountryDetails", "Transfer", new { pm_RRN = 0 }, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal", @class = "btn btn-default action_btn" })
</div>
    

    
<div class="row">
    <div class="column">
        <div class="card">
            <h4 style="text-align: center">Ocean</h4>

            <div class="bodyScrollY">
                <table class="table table-hover">
                    <colgroup>
                        <col id="col_01" style="width: 25px;">
                        <col id="col_03" style="width: 120px;">
                        <col id="col_04" style="width: 30px;">
                        <col id="col_05" style="width: 30px;">
                        <col id="col_06" style="width: 150px;">
                        <col id="col_07" style="width: 40px;">
                        <col id="col_08" style="width: 5px;">
                    </colgroup>
                    <thead>
                        <tr>
                            <th style="text-align: center;">
                                @Model.Ocean.Count().ToString()
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Ocean.First().from_country_id)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Ocean.First().to_country)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Ocean.First().to_loc_id)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Ocean.First().to_loc_name)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Ocean.First().transit_days)
                            </th>
                            <th style="text-align: center;">
                                &nbsp;
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            if (Model.Ocean != null)
                            {
                                var records = 0;
                                foreach (var item in Model.Ocean)
                                {
                                    <tr>
                                        <td align="center">
                                            @Html.ValueFor(modelItem => item.i)
                                        </td>
                                        @if (records < item.i) 
                                        { 
                                            <td rowspan="@item.group_count" style="padding-left: 15px;">
                                                @Ajax.ActionLink(item.from_country_id.ToString() + " - " + item.from_country_name, "ShowTransit_CountryBulk", "Transfer", new { pm_from_country_id = item.from_country_id, pm_ship_method = item.ship_method }, new AjaxOptions { UpdateTargetId = "myBulk", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#bulkModal" })
                                            </td>
                                            records += item.group_count;
                                        }
                                        <td align="center">
                                            @Html.ValueFor(modelItem => item.to_country)
                                        </td>
                                        <td align="center">
                                            @Html.ValueFor(modelItem => item.to_loc_id)
                                        </td>
                                        <td>
                                            @Html.ValueFor(modelItem => item.to_loc_name)
                                        </td>
                                        <td align="right" style="padding-right: 20px;">
                                            @Html.ValueFor(modelItem => item.transit_days)
                                        </td>
                                        <td align="right">
                                            @Html.ActionLink("Delete", "GoDeleteTransit_Country", "Transfer", new { pm_RRN = @item.i, pm_ship_method = "Ocean" }, new { onclick = "return confirm('Are you sure you want to delete this record?');", @class = @attr_css })
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
        
    <div class="column">
        <div class="card">
            <h4 style="text-align: center">Air</h4>

            <div class="bodyScrollY">
                <table class="table table-hover">
                    <colgroup>
                        <col id="col_01" style="width: 25px;">
                        <col id="col_03" style="width: 120px;">
                        <col id="col_04" style="width: 30px;">
                        <col id="col_05" style="width: 30px;">
                        <col id="col_06" style="width: 150px;">
                        <col id="col_07" style="width: 40px;">
                        <col id="col_08" style="width: 5px;">
                    </colgroup>
                    <thead>
                        <tr>
                            <th style="text-align: center;">
                                @Model.Air.Count().ToString()
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Air.First().from_country_id)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Air.First().to_country)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Air.First().to_loc_id)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Air.First().to_loc_name)
                            </th>
                            <th style="text-align: center;">
                                @Html.DisplayNameFor(model => model.Air.First().transit_days)
                            </th>
                            <th style="text-align: center;">
                                &nbsp;
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            if (Model.Air != null)
                            {
                                var records = 0;
                                foreach (var item in Model.Air)
                                {
                                    <tr>
                                        <td align="center">
                                            @Html.ValueFor(modelItem => item.i)
                                        </td>
                                        @if (records < item.i) 
                                        { 
                                            <td rowspan="@item.group_count" style="padding-left: 15px;">
                                                @Ajax.ActionLink(item.from_country_id.ToString() + " - " + item.from_country_name, "ShowTransit_CountryBulk", "Transfer", new { pm_from_country_id = item.from_country_id, pm_ship_method = item.ship_method }, new AjaxOptions { UpdateTargetId = "myBulk", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#bulkModal" })
                                            </td>
                                            records += item.group_count;
                                        }
                                        <td align="center">
                                            @Html.ValueFor(modelItem => item.to_country)
                                        </td>
                                        <td align="center">
                                            @Html.ValueFor(modelItem => item.to_loc_id)
                                        </td>
                                        <td>
                                            @Html.ValueFor(modelItem => item.to_loc_name)
                                        </td>
                                        <td align="right" style="padding-right: 20px;">
                                            @Html.ValueFor(modelItem => item.transit_days)
                                        </td>
                                        <td align="right">
                                            @Html.ActionLink("Delete", "GoDeleteTransit_Country", "Transfer", new { pm_RRN = @item.i, pm_ship_method = "Air" }, new { onclick = "return confirm('Are you sure you want to delete this record?');", @class = @attr_css })
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

