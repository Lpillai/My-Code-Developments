<form id="submit-button">
    <div class="row">
        <div class="form-group">
            <label class="control-label col-md-1" style="text-align: right; padding-top: 7px;">To Location</label>
            @Html.DropDownList("pmTo", (SelectList)ViewData["List_LocGrp"], new { @class = "form-control col-md-1" })
            <label class="control-label col-md-1" style="text-align: right; padding-top: 7px;">Requested Date</label>
            <input type="date" id="pmDate" name="pmDate" min="@DateTime.Now.ToString("yyyy-MM-dd")" value="@DateTime.Now.ToString("yyyy-MM-dd")" autocomplete="off" onkeyup="onEnterPressed(event);" class="form-control col-md-1" style="font-size: 14px;" />
            <label class="control-label col-md-1" style="color: transparent">Search</label>
            <input type="button" id="btn_search" value="Search" onclick="goSearch();" class="btn btn-default" />
        </div>
    </div>
</form>


<div id="orders">
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

