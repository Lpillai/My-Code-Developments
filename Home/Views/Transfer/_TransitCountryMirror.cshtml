@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}


@using (Html.BeginForm("GoMirrorTransitTime_Country", "Transfer", FormMethod.Post, new { id = "transitForm", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&Chi;</span>
        </button>
        <h4 class="modal-title" id="detailsModalLabel">
            <span>Mirror Country Settings</span>
        </h4>
    </div>
    <div class="modal-body">
        <div class="form-horizontal">
            <div class="form-group">
                @Html.Label("Source", htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @if (ViewData["List_SourceCountry"] != null)
                {
                    @Html.DropDownList("source_country_id", (SelectList)ViewData["List_SourceCountry"], new { id = "source_country_id", @class = "form-control col-md-8", style = "font-size: 16px;" })
                }
            </div>
            <div class="form-group">
                @Html.Label("Target", htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @if (ViewData["List_TargetCountry"] != null)
                {
                    @Html.DropDownList("target_country_id", (SelectList)ViewData["List_TargetCountry"], new { id = "target_country_id", @class = "form-control col-md-8", style = "font-size: 16px;" })
                }
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <input type="submit" value="Save" class="btn btn-primary" onclick="return confirm('Save mirroring?');" @attr_html />
    </div>
}

