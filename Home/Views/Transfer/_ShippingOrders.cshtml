@model RuntimeVariables.Shipping_Orders

@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}




<script type="text/javascript">
    $(document).ready(function () {    
        document.getElementById('btn_search').removeAttribute("disabled");
        //document.getElementById('btn_search').value = "Search";
        $("#loading").fadeOut();
                
        $("#btnModify").click(function () {
            document.getElementById('btnModify').setAttribute('disabled', 'disabled');
            document.getElementById('btnModify').value = "Processing...";
            document.getElementById('ModifyForm').submit();
        });
    })
</script>
<script type="text/javascript">
    function cancelPreloads() {
        var select = true;

        var cnt = 0;
        var selectElement = document.getElementsByClassName("preloadsCheck");
        for (var i = 0; i < selectElement.length; i++) {
            if (selectElement[i].checked)
                cnt = cnt + 1;
        }

        if (cnt > 0)
            select = false;

        for (var i = 0; i < selectElement.length; i++) {
            selectElement[i].checked = select;
        }
    }

    function cancelPOs() {
        var select = true;

        var cnt = 0;
        var selectElement = document.getElementsByClassName("posCheck");
        for (var i = 0; i < selectElement.length; i++) {
            if (selectElement[i].checked)
                cnt = cnt + 1;
        }

        if (cnt > 0)
            select = false;

        for (var i = 0; i < selectElement.length; i++) {
            selectElement[i].checked = select;
        }
    }
</script>




<style>
    .bulkScrollY {
        overflow: auto;
        display: inline-block;
        height: calc(100vh - 360px);
        width: 100%;
    }

    thead tr th {
        position: sticky;
        top: 0;
        background: #ffffff;
        text-align: center;
    }

    .table > tbody > tr > td {
        vertical-align: middle;
    }

    td.display {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .key {
        border: 0px none transparent;
        background-color: transparent;
        outline: none;
        padding-top: 5px;
        /*width: 80px;*/
        /*text-align: center;*/
    }


    /* Float four columns side by side */
    .column {
        float: left;
        /*width: 50%;
        width: 720px;*/
        padding: 0 10px;
    }

    /* Remove extra left and right margins, due to padding */
    .row {
        margin: 15px -5px;
    }
        /* Clear floats after the columns */
        .row:after {
            content: "";
            display: table;
            clear: both;
        }

    .card {
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
        padding: 16px;
        text-align: left;
        background-color: #f1f1f1;
    }

    /*
    input[type=checkbox] {
        background-color: white;
        border-radius: 2px;
        outline: 1px solid skyblue;
        -webkit-appearance: none;
        -moz-appearance: none;
        width: 17px;
        height: 17px;
        cursor: pointer;
        position: relative;
    }

        input[type=checkbox]:focus {
            outline: 1px solid rgba(0, 0, 0, 0.2);
        }

        input[type=checkbox]:checked {
            background-color: #409fd6;
            background: #409fd6 url("data:image/gif;base64,R0lGODlhCwAKAIABAP////3cnSH5BAEKAAEALAAAAAALAAoAAAIUjH+AC73WHIsw0UCjglraO20PNhYAOw==") 3px 3px no-repeat;
        }*/
</style>




<div style="margin-top: -20px;">
    @using (Html.BeginForm("RunExpectedShipDateModifying", "Transfer", null, FormMethod.Post, new { id = "ModifyForm", enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()

        <div class="row" style="display: @(Model.shift_days == 0 ? "none" : "initial")">
            <div class="form-group">
                @Html.Hidden($"pm_orders.P21URL", Model.P21URL)
                @Html.Hidden($"pm_orders.from_loc", Model.from_loc)
                @Html.Hidden($"pm_orders.required_date", ViewData["pm_theDate"])
                <label class="control-label col-md-1" style="text-align: right; padding-top: 7px;">Shift Days</label>
                <input type="number" name="pm_orders.shift_days" value="@Model.shift_days" class="form-control col-md-1" style="font-size: 14px;" />
                &nbsp;&nbsp;
                <input id="btnModify" type="submit" value="Modify" class="btn btn-primary btn-large" @attr_html />
            </div>
        </div>
        <div class="row" style="margin-top: -15px;">
            <div class="column" style="width: 40%;">
                <div class="card">
                    <h3 style="text-align: center">
                        @Html.Raw("Preload")
                    </h3>
                    <div class="bulkScrollY">
                        @{
                            if (Model.preloads == null || Model.preloads.Count() <= 0) 
                            { 
                                <br>
                                <div style="font-size: larger; text-align: center;">
                                    @Html.Raw("No data found.")
                                </div>
                            }
                            else
                            {
                                <table class="table table-hover">
                                    <colgroup>
                                        <col id="col_00" style="width: 25px;">
                                        <col id="col_01" style="width: 25px;">
                                        <col id="col_03" style="width: 70px;">
                                        <col id="col_04" style="width: 70px;">
                                        @*<col id="col_05" style="width: 75px;">*@
                                        <col id="col_06" style="width: 120px;">
                                        <col id="col_07" style="width: 105px;">
                                        <col id="col_08" style="width: 105px;">
                                        <col id="col_09" style="width: 135px;">
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th>
                                                <button onclick="cancelPreloads();">&#11197;</button>
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.Raw(Model.preloads.Count())
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.preloads[0].order_no)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.preloads[0].po_no)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.preloads[0].customer_id)
                                            </th>
                                            @*<th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.preloads[0].taker)
                                            </th>*@
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.preloads[0].required_date)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.preloads[0].expected_date)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.preloads[0].expected_ship_date)
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var index = 0;
                                            foreach (var item in Model.preloads)
                                            {
                                                <tr>
                                                    <td align="center">
                                                        @Html.CheckBox($"pm_orders.preloads[{index}].chk", item.chk, new { @class = "preloadsCheck", @style = "height: 20px;" })
                                                    </td>
                                                    <td align="center">
                                                        @Html.Raw(item.no.ToString())
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.preloads[{index}].order_no", item.order_no)
                                                        @Html.Raw(item.order_no)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.preloads[{index}].po_no", item.po_no)
                                                        @Html.Raw(item.po_no.ToString())
                                                    </td>
                                                    <td align="center">
                                                        @Html.Raw(item.customer_id.ToString())
                                                    </td>
                                                    @*<td>
                                                        @Html.Raw(item.taker)
                                                    </td>*@
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.preloads[{index}].requested_date", item.requested_date)
                                                        @Html.Hidden($"pm_orders.preloads[{index}].expedite_date", item.expedite_date)
                                                        @Html.Hidden($"pm_orders.preloads[{index}].required_date", item.required_date)
                                                        @Html.DisplayFor(modelItem => item.required_date)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.preloads[{index}].expected_date", item.expected_date)
                                                        @Html.DisplayFor(modelItem => item.expected_date)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.preloads[{index}].expected_ship_date", item.expected_ship_date)
                                                        @Html.DisplayFor(modelItem => item.expected_ship_date)
                                                    </td>
                                                </tr>
                                                index++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="column" style="width: 59%; margin-right: -10px;">
                <div class="card" style="padding-right: 5px;">
                    <h3 style="text-align: center">
                        @Html.Raw("Suppliers PO")
                    </h3>
                    <div class="bulkScrollY">
                        @{
                            if (Model == null || Model.pos == null || Model.pos.Count() <= 0) 
                            { 
                                <br>
                                <div style="font-size: larger; text-align: center;">
                                    @Html.Raw("No data found.")
                                </div>
                            }
                            else
                            {
                                <table class="table table-hover">
                                    <colgroup>
                                        <col id="col_00" style="width: 25px;">
                                        <col id="col_01" style="width: 40px;">
                                        <col id="col_02" style="width: 80px;">
                                        <col id="col_03" style="width: 70px;">
                                        <col id="col_04" style="width: 60px;">
                                        <col id="col_05" style="width: 70px;">
                                        <col id="col_06" style="width: 190px;">
                                        <col id="col_07" style="width: 70px;">
                                        <col id="col_08" style="width: 120px;">
                                        <col id="col_09" style="width: 120px;">
                                        <col id="col_10" style="width: 145px;">
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th>
                                                <button onclick="cancelPOs();">&#11197;</button>
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.Raw(Model.pos.Count())
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].po_no)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].vendor_id)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].location_id)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].line_no)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].item_id)
                                            </th>
                                            @*<th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].extended_desc)
                                            </th>*@
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].qty_ordered)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].required_date)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].expected_date)
                                            </th>
                                            <th style="text-align: center;">
                                                @Html.DisplayNameFor(model => model.pos[0].expected_ship_date)
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var index = 0;
                                            foreach (var item in Model.pos)
                                            {
                                                <tr>
                                                    <td align="center">
                                                        @Html.CheckBox($"pm_orders.pos[{index}].chk", item.chk, new { @class = "posCheck" })
                                                    </td>
                                                    <td align="center">
                                                        @Html.ValueFor(modelItem => item.no)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.pos[{index}].po_no", item.po_no)
                                                        @Html.ValueFor(modelItem => item.po_no)
                                                    </td>
                                                    <td align="center">
                                                        @Html.ValueFor(modelItem => item.vendor_id)
                                                    </td>
                                                    <td align="center">
                                                        @Html.ValueFor(modelItem => item.location_id)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.pos[{index}].line_no", item.line_no)
                                                        @Html.ValueFor(modelItem => item.line_no)
                                                    </td>
                                                    <td data-toggle="tooltip" data-placement="right" title="@Html.DisplayFor(modelItem => item.extended_desc)" class="display">
                                                        @Html.Hidden($"pm_orders.pos[{index}].item_id", item.item_id)
                                                        @Html.ValueFor(modelItem => item.item_id)
                                                    </td>
                                                    <td align="right">
                                                        @Html.DisplayFor(modelItem => item.qty_ordered)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.pos[{index}].required_date", item.required_date)
                                                        @Html.DisplayFor(modelItem => item.required_date)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.pos[{index}].expected_date", item.expected_date)
                                                        @Html.DisplayFor(modelItem => item.expected_date)
                                                    </td>
                                                    <td align="center">
                                                        @Html.Hidden($"pm_orders.pos[{index}].expected_ship_date", item.expected_ship_date)
                                                        @Html.DisplayFor(modelItem => item.expected_ship_date)
                                                    </td>
                                                </tr>
                                                index++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
        <div style="font-size: larger; color: darkorange;">
            @Html.Raw("※ Please do NOT hit the ENTER key on this screen.")
        </div>
    }
</div>


