@using RuntimeVariables;
@model IEnumerable<BuySheet_TransitTime_DefaultAir>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;

    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}

@*
@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/jqueryval")
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script src="~/Scripts/jquery-3.4.1.js"></script>
*@



<style>
    .bodyScrollY {
        overflow: auto;
        display: inline-block;
        height: calc(100vh - 235px);
        width: 100%;
    }

    thead tr th {
        position: sticky;
        top: 0;
        background: #ffffff;
        text-align: center;
    }

    .table > tbody > tr > td {
        vertical-align: middle;
    }

    /* ------------------------------------------------------------------------------------------------------------------------------------ */

    .action_btn {
        color: steelblue;
        border-style: none;
    }

    a.action_btn:hover, input.action_btn:hover {
        /*color: white;*/
        background-color: lightblue;
    }
</style>


<script type="text/javascript">
    function exitCountry() {
        var country = document.getElementById('from_country_id');
        document.getElementById('pmTransit_from_country_name').value = country.options[country.selectedIndex].text;
    }
    
    function exitLocation() {
        var location = document.getElementById('to_loc_id');
        document.getElementById('pmTransit_to_loc_name').value = location.options[location.selectedIndex].text;
    }
</script>




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>


<div class="modal fade" id="detailsModal" tabindex="-1" role="dialog" aria-labelledby="detailsModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content" id="myDetails">
            @using (Html.BeginForm("GoSaveTransit_DefaultAir", "Transfer", FormMethod.Post, new { id = "transitForm", enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("pmTransit.from_country_name")
                @Html.Hidden("pmTransit.to_loc_name")

                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&Chi;</span>
                    </button>
                    <h4 class="modal-title" id="detailsModalLabel">
                        <span>New</span>
                    </h4>
                </div>
                <div class="modal-body">
                    <div class="form-horizontal">
                        <div class="form-group">
                            @Html.LabelFor(model => model.First().item_id, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                            <input type="text" name="pmTransit.item_id" autocomplete="off" class="col-md-8 input-sm form-control" style="font-size: large;" />
                        </div>
                        <div class="form-group">
                            @Html.LabelFor(model => model.First().from_country_id, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                            @if (ViewData["List_fromCountry"] != null)
                            {
                                @Html.DropDownList("pmTransit.from_country_id", (SelectList)ViewData["List_fromCountry"], new { id = "from_country_id", onfocusout = "exitCountry();", @class = "form-control col-md-8", style = "font-size: medium;" })
                            }
                        </div>
                        <div class="form-group">
                            @Html.LabelFor(model => model.First().to_loc_id, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                            @if (ViewData["List_toLocation"] != null)
                            {
                                @Html.DropDownList("pmTransit.to_loc_id", (SelectList)ViewData["List_toLocation"], new { id = "to_loc_id", onfocusout = "exitLocation();", @class = "form-control col-md-8", style = "font-size: medium;" })
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <input type="submit" value="Save" class="btn btn-primary" onclick="return confirm('Save this transit record?');" @attr_html />
                </div>
            }
        </div>
    </div>
</div>




<div class="row" style="padding: 0 10px 10px 15px;">
    <a href="#detailsModal" class="btn btn-default action_btn" data-toggle="modal" onclick="applyPO();">Create One Record</a>
    @*&nbsp;
    @Html.ActionLink("Download", "GoExportDefaultAirSheet", "Transfer", null, new { @target = "_blank", @class = "btn btn-default action_btn" })*@
</div>


<div class="bodyScrollY">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>
                    @Model.Count().ToString()
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.item_id)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.item_desc)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.from_country_name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.to_loc_name)
                </th>
                <th>
                    &nbsp;
                </th>
            </tr>
        </thead>
        <tbody>
            @{
                if (Model == null)
                { 
                    <tr>
                        <td colspan="6" align="center">No data found.</td>
                    </tr>
                }
                else
                {
                    var i = 0;
                    foreach (var item in Model)
                    {
                        i++;

                        <tr>
                            <td align="right">
                                @Html.Raw(i)
                            </td>
                            <td>
                                @Html.ValueFor(modelItem => item.item_id)
                            </td>
                            <td>
                                @Html.ValueFor(modelItem => item.item_desc)
                            </td>
                            <td>
                                @Html.ValueFor(modelItem => item.from_country_name)
                            </td>
                            <td>
                                @Html.ValueFor(modelItem => item.to_loc_name)
                            </td>
                            <td align="center">
                                @Html.ActionLink("Delete", "GoDeleteTransit_DefaultAir", "Transfer", new { pm_item_id = item.item_id, pm_from_country_id = item.from_country_id, pm_to_loc_id = item.to_loc_id }, new { onclick = "return confirm('Are you sure you want to delete this record?');", @class = @attr_css })
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>


@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

