<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>





<div class="row" style="margin: 10px 20px 0 20px;">
    <div class="form-group" style="display: inline-block;">
        @Html.Label("From Country", htmlAttributes: new { @class = "control-label" })
        <br>
        @Html.DropDownList("pm_country_cd", (SelectList)ViewData["List_fromCountry"], htmlAttributes: new { @class = "form-control", style = "font-size: large; width: 320px; max-width: 320px;" })
        <div style="margin: 5px 0 0 10px; font-size: medium;">
            &nbsp;
        </div>
    </div>
    <div class="form-group" style="display: inline-block;">
        @Html.Label("To Location", htmlAttributes: new { @class = "control-label" })
        <br>
        @*@Html.DropDownList("pm_loc_cd", Enumerable.Empty<SelectListItem>(), htmlAttributes: new { @class = "form-control mycombo" })*@
        @Html.DropDownList("pm_loc_cd", (SelectList)ViewData["List_toLocationGroup"], htmlAttributes: new { @class = "form-control", style = "font-size: large; width: 450px; max-width: 450px;" })
        <div id="loc_id" style="margin: 5px 0 0 10px; font-size: medium;">
            @ViewData["loc_IDs"].ToString()
        </div>
    </div>
    <div class="form-group" style="display: inline-block;">
        <br>
        <input type="button" id="btn_search" value="Search" class="btn btn-default" onclick="goSearch();" />
        <div style="margin: 5px 0 0 10px; font-size: medium;">
            &nbsp;
        </div>
    </div>
</div>


