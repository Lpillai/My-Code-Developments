<script type="text/javascript">
    function onCountryChange() {
        //alert('onCountryChange');
        $("#pm_loc_cd").prop("disabled", true);
        var pm_country_cd = $("#pm_country_cd").val();
        var items = '';
        $.ajax({
            cache: false,
            url: '@Url.Action("GetLocationGrpList", "Transfer")',
            data: { "pm_country_cd": pm_country_cd },
            type: "GET",
            contentType: "application/json; charset=utf-8",
            datatype: JSON,
            success: function (result) {
                $(result).each(function () {
                    items += "<option value='" + this.group_id + "'>" + this.loc_cd + "</option>";
                });
                //alert(items);
                $('#pm_loc_cd').html(items);
                $("#pm_loc_cd").prop("disabled", false);
            },
            error: function (data) {
                alert("Location data not found.\r\n" + data);
            }
        });

        //alert("1");
        return new Promise((res) => { setTimeout(() => { res(); }, 500); });
    }

        
    function onLocationChange() {
        //alert('onLocationChange');
        document.getElementById('loc_id').innerHTML = "";
        var pm_country_cd = $("#pm_country_cd").val();
        var pm_group_id = $("#pm_loc_cd").val();
        //alert(pm_country_cd + "\r\n" + pm_group_id);
        if (pm_group_id != null) {
            $.ajax({
                cache: false,
                url: '@Url.Action("GetLocationIDs", "Transfer")',
                data: { "pm_country_cd": pm_country_cd, "pm_group_id": pm_group_id },
                type: "GET",
                contentType: "application/json; charset=utf-8",
                datatype: JSON,
                success: function (result) {
                    //alert(result);
                    document.getElementById('loc_id').innerHTML = result;
                },
                error: function () {
                }
            });
        }
        //alert("2");
    }

        
    function goSearch() {
        //alert('goSearch');
        document.getElementById('btn_search').setAttribute('disabled', 'disabled');

        $("#loading").fadeIn();
        var target = document.getElementById('loading');
        var spinner = new Spinner(opts).spin(target);
            
        var pm_country_cd = $("#pm_country_cd").val();
        var pm_location_cd = $("#pm_loc_cd").val();
        $("#output").load('@Url.Action("ShippingCalendar_Details", "Transfer")?pm_country_cd=' + pm_country_cd + '&pm_location_cd=' + pm_location_cd);
    }


    function pageLoad() {
        //alert('pageLoad');

        //$("#pm_country_cd").change(async function () { await onCountryChange(); onLocationChange(); });
        $("#pm_country_cd").change(function () { onCountryChange(); onLocationChange(); });
        $("#pm_loc_cd").change(function () { onLocationChange(); });
        //alert('1');
        @*
        var tmp_country_cd = '@(TempData["pm_country_cd"])';
        if (tmp_country_cd != null && tmp_country_cd != '') {
            var mySelect_country = document.getElementById('pm_country_cd');
            for(var i, j = 0; i = mySelect_country.options[j]; j++) {
                if(i.value == tmp_country_cd) {
                    mySelect_country.selectedIndex = j;
                    break;
                }
            }
        }
        //alert('2');
        
        //await onCountryChange();
        onCountryChange();
        //alert('3');

        var tmp_location_cd = '@(TempData["pm_location_cd"])';
        var mySelect_loc = document.getElementById('pm_loc_cd');
        if (tmp_location_cd != null && tmp_location_cd != '') {
            for (var i, j = 0; i = mySelect_loc.options[j]; j++) {
