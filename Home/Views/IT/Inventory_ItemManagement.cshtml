@using RuntimeVariables;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;
}




<style type="text/css">
</style>




<script type="text/javascript">
    //$(document).ready(function () {   
    //});
</script>
<script type="text/javascript">
    function onLocationChang() {
        //alert('on');
        $("#loading").fadeIn();
        var target = document.getElementById('loading');
        var spinner = new Spinner(window.opts).spin(target);

        var dpt = $("#dpt").val();
        //alert(dpt);
        var bin_cd = $("#pm_location option:selected").val();
        //alert(bin_cd);
        $("#inventory").load('@Url.Action("ShowInventoryDetails", "IT")?pm_dpt='+dpt+'&pm_bin_cd='+bin_cd);
    }
    
    window.addEventListener("load", onLocationChang);
</script>


<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>




<div class="row" style="margin-bottom: 10px;">
    @Html.Hidden("dpt", ViewData["dpt"].ToString(), null)

    <div class="form-group">
        @Html.Label("Location", htmlAttributes: new { @class = "control-label col-md-1", @style = "text-align: right; padding-top: 7px;" })
        <div class="col-md-7">
            @Html.DropDownList("pm_location", (SelectList)ViewData["List_Locations"], new { @class = "form-control", @onchange="onLocationChang()", style = "font-size: medium;" })
        </div>
    </div>
</div>


<div id="inventory">
</div>



@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

