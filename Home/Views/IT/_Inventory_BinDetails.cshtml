@model RuntimeVariables.Inventory_Bin

@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}




<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: Arial, Helvetica, sans-serif;
    }

    /* Remove extra left and right margins, due to padding */
    .row {
        margin: 0 -5px;
    }
        /* Clear floats after the columns */
        .row:after {
            content: "";
            display: table;
            clear: both;
        }
</style>




<script type="text/javascript">
</script>




@using (Html.BeginForm("Inventory_GoSaveBin", "IT", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.bin_uid)
    @Html.HiddenFor(model => model.dpt)

    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&Chi;</span>
        </button>
        <h4 class="modal-title" id="detailsModalLabel">
            @if ((bool)ViewData["isNew"])
            {
                <span>New</span>
            }
            else
            {
                @Html.ValueFor(model => model.bin_uid)
                @Html.Raw(" - ")
                @Html.ValueFor(model => model.z_memo)
            }
        </h4>
    </div>
    <div class="modal-body">
        <div class="form-horizontal">
            <div class="form-group">
                @Html.LabelFor(model => model.bin_cd, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                <input type="text" name="bin_cd" value="@Model.bin_cd" autocomplete="off" class="col-md-8 input-sm form-control" style="font-size: 14px;" />
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.z_memo, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                <input type="text" name="z_memo" value="@Model.z_memo" autocomplete="off" class="col-md-8 input-sm form-control" style="font-size: 14px;" />
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.parent_uid, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                <input type="number" name="parent_uid" value="@Model.parent_uid" autocomplete="off" class="col-md-8 input-sm form-control" style="font-size: 14px;" />
            </div>
            <div class="form-group">
                @Html.Label("Status", htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                <select id="z_status" name="z_status" class="col-md-8 form-control" style="font-size: 14px;">
                    <option value="">Active</option>
                    <option value="D">Deleted</option>
                </select>
            </div>
            @if (!(bool)ViewData["isNew"])
            {
                <div class="form-group">
                    @Html.LabelFor(model => model.storage_code, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                    <span class="col-md-4" style="margin: 5px 0 0 0;">@Html.ValueFor(model => model.storage_code)</span>
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.bin_hierarchy, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                    <span class="col-md-4" style="margin: 5px 0 0 0;">@Html.ValueFor(model => model.bin_hierarchy)</span>
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.z_date, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                    <span class="col-md-4" style="margin: 5px 0 0 0;">@Html.ValueFor(model => model.z_date)</span>
                </div>
                <div class="form-group">
                    @Html.LabelFor(model => model.z_usr, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                    <span class="col-md-4" style="margin: 5px 0 0 0;">@Html.ValueFor(model => model.z_usr)</span>
                </div>
            }
        </div>
    </div>
    <div class="modal-footer">
        <input type="submit" value="Save" @attr_html class="btn btn-primary" onclick="return confirm('Save this bin?');" />
    </div>
}


@if (TempData["message"] != null)
{
    <script type="text/javascript">
    var message = @Html.Raw(Json.Encode(TempData["message"]));
    alert(message);
    </script>
}

