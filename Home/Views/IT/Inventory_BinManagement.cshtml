@using RuntimeVariables;
@model Inventory_BinData
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;
}

@helper SayHello(IEnumerable<Inventory_BinTree> wkList)
{
    <ul>
        @foreach(var item in wkList)
        {
            if(@item.child_bins.Count() == 0)
            {
                <li><span> @item.bin_name </span></li>
                @*<li><span> @Ajax.ActionLink(@item.bin_name, "ShowBinDetails", "IT", new { pm_uid = @item.bin_uid }, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal" }) </span></li>*@
            }
            else
            {
                <li>
                    <span><i class="fa fa-minus-square"></i> @item.bin_name </span>
                    @SayHello(item.child_bins)
                </li>
            }
        }
    </ul>
}




<style>
    .bodyScrollY {
        overflow: auto;
        display: inline-block;
        height: calc(100vh - 115px);
    }

    thead tr th {
        position: sticky;
        top: 0;
        background-color: #eee;
        text-align: center;
    }

    .tree {
        min-height: 20px;
        padding: 10px;
        /*margin-bottom: 5px;*/
        background-color: #fbfbfb;
        -webkit-border-radius: 6px;
        -moz-border-radius: 6px;
        border-radius: 6px;
        -webkit-box-shadow: inset 0 3px 3px rgba(0, 0, 0, 0.05);
        -moz-box-shadow: inset 0 3px 3px rgba(0, 0, 0, 0.05);
        box-shadow: inset 0 3px 3px rgba(0, 0, 0, 0.05)
    }

        .tree li {
            list-style-type: none;
            margin: 0;
            padding: 10px 5px 0 5px;
            position: relative
        }

            .tree li::before, .tree li::after {
                content: '';
                left: -20px;
                position: absolute;
                right: auto
            }

            .tree li::before {
                border-left: 1px solid #999;
                bottom: 50px;
                height: 100%;
                top: 0;
                width: 1px
            }

            .tree li::after {
                border-top: 1px solid #999;
                height: 20px;
                top: 30px;
                width: 25px
            }

            .tree li span {
                -moz-border-radius: 5px;
                -webkit-border-radius: 5px;
                border: 1px solid #999;
                border-radius: 5px;
                display: inline-block;
                padding: 3px 8px;
                text-decoration: none
            }

            .tree li.parent_li > span {
                cursor: pointer
            }

        .tree > ul > li::before, .tree > ul > li::after {
            border: 0
        }

        .tree li:last-child::before {
            height: 30px
        }

        .tree li.parent_li > span:hover, .tree li.parent_li > span:hover + ul li span {
            /*background: #eee;*/
            background-color: rgb(255 205 143 / 0.2);
            border: 1px solid #94a0b4;
            color: #000
        }
</style>




<script>
    $(function () {
        $('.tree li:has(ul)').addClass('parent_li').find(' > span').attr('title', 'Collapse this branch');
        $('.tree li.parent_li > span').on('click', function (e) {
            var children = $(this).parent('li.parent_li').find(' > ul > li');
            if (children.is(":visible")) {
                children.hide('fast');
                $(this).attr('title', 'Expand this branch').find(' > i').addClass('fa-plus-square').removeClass('fa-minus-square');
            } else {
                children.show('fast');
                $(this).attr('title', 'Collapse this branch').find(' > i').addClass('fa-minus-square').removeClass('fa-plus-square');
            }
            e.stopPropagation();
        });
    });
</script>




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>




<div class="modal fade" id="detailsModal" tabindex="-1" role="dialog" aria-labelledby="detailsModalLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" id="myDetails">
        </div>
    </div>
</div>




<div class="row">
    <div style="width: 400px;" class="tree bodyScrollY">
        <ul>
            <li>
                <span><i class="fa fa-folder-open"></i> SBS </span>
                @SayHello(Model.theTree)
            </li>
        </ul>
    </div>

    <div style="width: calc(100vw - 450px); padding: 0 10px 0 15px;" class="bodyScrollY">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="width: 40px; max-width: 40px;">
                        @Model.theList.Count().ToString()
                    </th>
                    <th style="width: 60px; max-width: 60px;">
                        @Ajax.ActionLink("Create", "ShowBinDetails", "IT", new { pm_dpt = ViewData["dpt"].ToString(), pm_uid = 0 }, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal" })
                        <br>
                        @Html.DisplayNameFor(model => model.theList[0].bin_uid)
                    </th>
                    <th style="width: 60px; max-width: 60px;">
                        @Html.DisplayNameFor(model => model.theList[0].parent_uid)
                    </th>
                    <th style="width: 80px; max-width: 80px;">
                        @Html.DisplayNameFor(model => model.theList[0].bin_cd)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.theList[0].z_memo)
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.theList)
                {
                    <tr>
                        <td align="right">
                            @Html.DisplayFor(modelItem => item.rrn)
                        </td>
                        <td align="right" style="padding-right: 30px;">
                            @Html.DisplayFor(modelItem => item.bin_uid)
                        </td>
                        <td align="right" style="padding-right: 30px;">
                            @Html.DisplayFor(modelItem => item.parent_uid)
                        </td>
                        <td style="padding-left: 10px;">
                            @*@Html.DisplayFor(modelItem => item.bin_cd)*@
                            @Ajax.ActionLink(@item.bin_cd, "ShowBinDetails", "IT", new { pm_dpt = ViewData["dpt"].ToString(), pm_uid = @item.bin_uid }, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal" })
                        </td>
                        <td style="padding-left: 10px;">
                            @Html.DisplayFor(modelItem => item.z_memo)
                            @*@Ajax.ActionLink(@item.z_memo, "ShowBinDetails", "IT", new { pm_uid = @item.bin_uid }, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal" })*@
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

