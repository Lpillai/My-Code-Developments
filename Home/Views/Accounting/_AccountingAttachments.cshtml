@model IEnumerable<RuntimeVariables.AccountingAttachment>

@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}




@using (Html.BeginForm("GoUpdateAttachment", "Accounting", new { pm_source = ViewData["source"].ToString(), pm_location_id = (int)ViewData["location_id"], pm_accounting_type = ViewData["accounting_type"].ToString(), pm_accounting_uid = (int)ViewData["accounting_uid"] }, FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    
    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&Chi;</span>
        </button>

        <h4 id="attachModalLabel" class="modal-title">
            @ViewData["accounting_type"] @ViewData["accounting_uid"] Attachments
        </h4>
    </div>

    <div class="modal-body">
        <div style="margin-top: 10px; padding: 5px 10px 5px 10px;">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="text-align:center;">
                            @Html.Hidden("AttachedCount", Model.Count().ToString(), null)
                            @Html.Raw(((Model == null || Model.Count() == 0) ? 0 : Model.Count() - 1).ToString())
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.attach_name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.tags)
                        </th>
                        <th>
                            &nbsp;
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model == null || Model.Count() <= 0)
                        { 
                            <tr>
                                <td colspan="4" style="text-align:center;">No data found.</td>
                            </tr>
                        }
                        else
                        {
                            int i = 0;
                            foreach (var item in Model)
                            {
                                if (item.z_status == "A")
                                {
                                    <tr id="tr_@i">
                                        <td align="right">
                                            @Html.Raw("New")
                                            @Html.Hidden($"pmAR[{i}].attach_uid", 0, null)
                                        </td>
                                        <td>
                                            @Html.TextBox($"pmAR[{i}].attachedFile", "", new { type = "file", id = $"attachedFile_{i}", onchange = $"isAddNewAttachment({i});", accept = ".pdf, .xlsx, image/*, .zip", @class = "form-control" })
                                        </td>
                                        <td id="tag_@i">
                                            @Html.ListBox($"pmAR[{i}].tags", new MultiSelectList((IEnumerable<SelectListItem>)ViewData["attach_tag"], "Value", "Text"), new { id = $"attachedTags_{i}", @class = "chzn-select" })
                                        </td>
                                        <td>
                                            @Html.Hidden($"pmAR[{i}].z_status", item.z_status, null)
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <tr id="tr_@i">
                                        <td align="right">
                                            @Html.Raw((i+1).ToString())
                                            @Html.Hidden($"pmAR[{i}].attach_uid", item.attach_uid, null)
                                        </td>
                                        <td>
                                            @Html.ActionLink(item.attach_name+item.attach_ext, "Get_attachment", "Accounting", new { pm_attach_uid = item.attach_uid }, new { target = "_blank" })
                                        </td>
                                        <td>
                                            @Html.Raw(item.attach_tag)
                                        </td>
                                        <td>
                                            @if(ViewData["source"].ToString() == "AR" || ViewData["source"].ToString() == "AP")
                                            {
                                                @Html.ActionLink(((char)10008).ToString(), "GoDeleteAttachment", new { pm_source = ViewData["source"].ToString(), pm_location_id = (int)ViewData["location_id"], pm_attach_file = item.attach_name+item.attach_ext, pm_attach_uid = item.attach_uid, pm_accounting_uid = item.accounting_uid }, new { style = "vertical-align: top;", onclick = "return confirm('Are you sure you want to delete this attachment?');" })
                                            }
                                        </td>
                                    </tr>
                                }

                                i++;
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
        
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    </div>
    
    <div class="modal-footer">
        <input type="submit" value="Save" class="btn btn-primary" style="font-size: medium;" onclick="return confirm('Save attachment list?');" @attr_html />
    </div>
}




