@model RuntimeVariables.Local_Address

@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}



<style>
</style>




@using (Html.BeginForm("GoUpdateLocalInformation_Address", "Accounting", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.Hidden("pm_address_id", ViewData["address_id"], null)
    @Html.Hidden("pm_address_name", ViewData["address_name"], null)
    @Html.Hidden("address_uid", Model.address_uid, null)

    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&Chi;</span>
        </button>
        <h4 class="modal-title" id="detailsModalLabel">
            @if ((bool)ViewData["pm_isNew"])
            {
                <span>New</span>
            }
            else
            {
                <span>@ViewData["address_name"].ToString()</span>
            }
        </h4>
    </div>
    <div class="modal-body">
        <div class="form-horizontal">
            <div class="form-group">
                @Html.LabelFor(model => model.address_type, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.DropDownList("address_type", new SelectList((IEnumerable<SelectListItem>)ViewData["AddressType"], "Value", "Text"), new { id = "address_type", @class = "form-control col-md-8 input-sm", style="font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.address_language, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.DropDownList("address_language", new SelectList((IEnumerable<SelectListItem>)ViewData["Language"], "Value", "Text"), new { id = "address_language", @class = "form-control col-md-8 input-sm", style="font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.address_name, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.TextBox("address_name", Model.address_name, new { @type = "text", @autocomplete = "off", @class = "col-md-8 input-sm form-control", style="font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.address_context, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.TextBox("address_context", Model.address_context, new { @type = "text", @autocomplete = "off", @class = "col-md-8 input-sm form-control", style="font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.address_zip, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.TextBox("address_zip", Model.address_zip, new { @type = "text", @autocomplete = "off", @class = "col-md-8 input-sm form-control", style="font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.address_country, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.TextBox("address_country", Model.address_country, new { @type = "text", @autocomplete = "off", @class = "col-md-8 input-sm form-control", style="font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.tax_id, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.TextBox("tax_id", Model.tax_id, new { @type = "text", @autocomplete = "off", @class = "col-md-8 input-sm form-control", style="font-size: medium;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.chk_deleted, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 5px 0 0 0;" })
                @Html.CheckBox("chk_deleted", Model.chk_deleted, new { style="margin-top: 5px;" })
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <input type="submit" value="Save" class="btn btn-primary" onclick="return confirm('Save this Address record?');" @attr_html />
    </div>
}




<script type="text/javascript">
</script>

