@using RuntimeVariables;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;
}

@*
@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/jqueryval")
@Scripts.Render("~/bundles/unobtrusive")
*@




<style type="text/css">
</style>




<script type="text/javascript">
    $(document).ready(function () {
    });
</script>
<script type="text/javascript">
    function onDateChang() {
        $("#loading").fadeIn();
        var target = document.getElementById('loading');
        var spinner = new Spinner(window.opts).spin(target);
        
        var pm_theDate = $("#pm_theDate").val();
        $("#details").load('@Url.Action("ShowCardStampList", "Taiwan")?&pm_theDate=' + pm_theDate);
    }
    
    function pageLoad() {
        onDateChang();
    }
    window.onload = pageLoad;
</script>




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>


<div class="row">
    <label class="control-label col-md-1" style="text-align: right; padding-top: 7px;">打卡日期</label>
    <input type="date" id="pm_theDate" value="@ViewData["pm_theDate"].ToString()" min="@(DateTime.Now.ToString("yyyy-MM-dd").Substring(0,8) + "01")" max="@(DateTime.Now.ToString("yyyy-MM-dd"))" autocomplete="off" onchange="onDateChang()" class="form-control input-sm" style="font-size: medium;" />
</div>


<div id="details">
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

