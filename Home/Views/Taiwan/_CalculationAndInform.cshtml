@model IEnumerable<RuntimeVariables.tw_CardStamp_Matching>

@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}


<script type="text/javascript">
    $(document).ready(function () {   
        //document.getElementById('btn_search').removeAttribute("disabled");   
        $("#loading").fadeOut();
    })
</script>


<style>
    .bodyScrollY {
        overflow: auto;
        display: inline-block;
        height: calc(100vh - 175px);
        width: 100%;
    }

    thead tr th {
        position: sticky;
        top: 0;
        background: #ffffff;
        text-align: center;
        z-index: 1;
        font-size: medium;
    }

    tbody td {
        font-size: large;
    }

    .table > tbody > tr > td {
        vertical-align: middle;
    }

    .table-hover tbody tr:hover td,
    .table-hover tbody tr:hover th {
        background-color: rgb(255 205 143 / 0.2);
    }

    /* ------------------------------------------------------------------------------------------------------------------------------------ */

    input[type=checkbox] {
        background-color: white;
        border-radius: 2px;
        outline: 1px solid skyblue;
        -webkit-appearance: none;
        -moz-appearance: none;
        width: 17px;
        height: 17px;
        cursor: pointer;
        position: relative;
    }

        input[type=checkbox]:focus {
            outline: 1px solid rgba(0, 0, 0, 0.2);
        }

        input[type=checkbox]:checked {
            background-color: #409fd6;
            background: #409fd6 url("data:image/gif;base64,R0lGODlhCwAKAIABAP////3cnSH5BAEKAAEALAAAAAALAAoAAAIUjH+AC73WHIsw0UCjglraO20PNhYAOw==") 3px 3px no-repeat;
        }
</style>


    

<div style="width: 80%; display: block; margin-left: auto; margin-right: auto; margin-top: 15px;">
    @using (Html.BeginForm("Go_Inform", "Taiwan", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
            
        <div class="row" style="margin-bottom: 10px;">
            <div class="col-md-9">
                &nbsp;
            </div>
            <div class="col-md-3">
                <input type="submit" value="送出通知" @attr_html class="btn btn-primary" onclick="return confirm('確認送出通知？');" />
            </div>
        </div>

        <div id="theSheet" class="bodyScrollY">
            <table class="table table-hover">
                <thead>
                    <tr>
                        @if (Model == null || Model.Count() <= 0)
                        {
                            <th style="max-width: 25px;">
                                @Html.Raw("0")
                            </th>
                        }
                        else
                        {
                            <th style="max-width: 25px;">
                                @Model.Count().ToString()
                            </th>
                        }
                        <th style="max-width: 50px;">
                            @Html.DisplayNameFor(model => model.full_name)
                        </th>
                        <th style="max-width: 100px;">
                            @Html.DisplayNameFor(model => model.check_stamp)
                        </th>
                        <th style="max-width: 520px;">
                            @Html.DisplayNameFor(model => model.msg)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model == null || Model.Count() <= 0)
                        {
                            <tr>
                                <td colspan="4" style="text-align:center;">No data found.</td>
                            </tr>
                        }
                        else
                        {
                            int i = 0;
                            foreach (var item in Model)
                            {
                                i++;
                                @Html.Hidden($"pm_Stamps[{i-1}].full_name", item.full_name)
                                @Html.Hidden($"pm_Stamps[{i-1}].account_id", item.account_id)
                                @Html.Hidden($"pm_Stamps[{i-1}].check_stamp", item.check_stamp)
                                @Html.Hidden($"pm_Stamps[{i-1}].msg", item.msg)

                                <tr>
                                    <td align="right" style="padding-right: 35px;">
                                        @Html.Raw(i)
                                        &nbsp;&nbsp;
                                        @Html.CheckBox($"pm_Stamps[{i-1}].chk", item.chk, new { @style = "vertical-align: sub;" })
                                    </td>
                                    <td style="font-size: large; padding-left: 20px;">
                                        @Html.DisplayFor(modelItem => item.full_name)
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.check_stamp)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.msg)
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}
