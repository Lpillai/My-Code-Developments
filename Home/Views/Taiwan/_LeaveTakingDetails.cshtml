    function onStartDateChange() {
        if (document.getElementById('day_end').value > document.getElementById('day_start').value) {
            //alert('1');
            CalculateHours();
        }
        else {
            //alert('2');
            document.getElementById('day_end').value = document.getElementById('day_start').value;
        }
    }


    function onEndDateChange() {
        if (document.getElementById('day_end').value > document.getElementById('day_start').value) {
            //alert('3');
            CalculateHours();
        }
        else {
            //alert('4');
            document.getElementById('day_start').value = document.getElementById('day_end').value;
        }
    }


    function CalculateHours() {
        //alert('in');
        //let datetime_s = new Date(document.getElementById('day_start').value + ' ' + document.getElementById('day_start_hour').value + ':00');
        //let datetime_e = new Date(document.getElementById('day_end').value + ' ' + document.getElementById('day_end_hour').value + ':00');
        let datetime_s = new Date(document.getElementById('day_start').value);
        let datetime_e = new Date(document.getElementById('day_end').value);
        //alert('datetime_s: ' + datetime_s + '\r\n' + 'datetime_e: ' + datetime_e);

        var hours = 0.0;
        $("#day_hours").prop("disabled", true);
        $("#day_hours").value = 0;
        //alert("ajax_call");
        $.when(ajax_call(datetime_s, datetime_e))
            .done(function () {
                //alert(hours);
                if (hours == null) {
                    alert("Error returned hours.");
                } else {
                    document.getElementById('day_hours').value = hours;
                }
            })
            .fail(function() {
                alert("Couldn't calculate hours.");
            });
        $("#day_hours").prop("disabled", false);

        function ajax_call(ds, de) {
            let dt_start = ds.getFullYear() + "-" + (ds.getMonth() + 1) + "-" + ds.getDate() + " " + ds.getHours() + ":" + ds.getMinutes();
            let dt_end = de.getFullYear() + "-" + (de.getMonth() + 1) + "-" + de.getDate() + " " + de.getHours() + ":" + de.getMinutes();
            //alert(dt_start + '\r\n' + dt_end);
            return $.ajax({
                    cache: false,
                    url: '@Url.Action("GetWorkingHours", "Taiwan")',
                    data: { "datetime_s": dt_start, "datetime_e": dt_end },
                    type: "GET",
                    contentType: "application/json; charset=utf-8",
                    datatype: JSON,
                    success: function (result) {
                        hours = result;
                    }/*,
                    error: function (jqXHR, textStatus, errorThrown) {
                        alert(textStatus + ": Calculattion error.\r\n" + formatErrorMessage(jqXHR, errorThrown));
                    }*/
            });
        }
    }
</script>




@using (Html.BeginForm("Go_SaveLeaveTaking", "Taiwan", new { pm_source = @ViewData["source"] }, FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.apply_uid)

    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&Chi;</span>
        </button>
        <h4 class="modal-title" id="detailsModalLabel">
            &nbsp;&nbsp;&nbsp;
            @if ((bool)ViewData["isNew"])
            {
                <span>新增</span>
            }
            else
            {
                @Html.Raw(Model.apply_uid.ToString("0000"))
            }
        </h4>
    </div>
    <div class="modal-body">
        <div class="form-horizontal" style="font-size: medium;">
            <div class="form-group">
                @Html.LabelFor(model => model.day_name, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 7px 0 0 0;" })
                @Html.DropDownList("day_id", (SelectList)ViewData["twLeaves"], new { @class = "form-control col-md-9", style = "font-size: large;" })
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.day_start, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 7px 0 0 0;" })
                <input type="datetime-local" id="day_start" name="day_start" value="@Model.day_start.ToString("yyyy-MM-dd HH:mm")" onchange = "onStartDateChange();" class="form-control col-md-9"  style="font-size: large;" />
                @*<div class="col-md-4">
                    <input type="date" id="day_start" name="day_start" value="@Model.day_start.ToString("yyyy-MM-dd")" onfocusout="onDateTimeChange();" class="form-control" style="font-size: large;" />
                </div>
                <div class="col-md-4">
                    @Html.DropDownList("day_start_hour", (SelectList)ViewData["TimeList_start"], new { onchange = "onStartTimeChange();", @class = "form-control", style = "font-size: large;" })
                    <input type="time" id="day_start_hour" name="day_start_hour" value="@Model.day_start.ToString("HH:mm")" onfocusout = "onDateTimeChange();" class="form-control" style="font-size: large;" />
                </div>*@
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.day_end, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 7px 0 0 0;" })
                <input type="datetime-local" id="day_end" name="day_end" value="@Model.day_end.ToString("yyyy-MM-dd HH:mm")" onchange = "onEndDateChange();" class="form-control col-md-9" style="font-size: large;" />
                @*<div class="col-md-4">
                    <input type="date" id="day_end" name="day_end" value="@Model.day_end.ToString("yyyy-MM-dd")" onfocusout="onDateTimeChange();" class="form-control" style="font-size: large;" />
                </div>
                <div class="col-md-4">
                    @Html.DropDownList("day_end_hour", (SelectList)ViewData["TimeList_end"], new { onchange = "onEndTimeChange();", @class = "form-control", style = "font-size: large;" })
                    <input type="time" id="day_end_hour" name="day_end_hour" value="@Model.day_end.ToString("HH:mm")" onfocusout = "onDateTimeChange();" class="form-control" style="font-size: large;" />
                </div>*@
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.day_hours, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 7px 0 0 0;" })
                <div class="col-md-9" style="font-size: medium; color: darkorange;">
                    <input type="number" id="day_hours" name="day_hours" value="@Model.day_hours" autocomplete="off" step="0.1" class="form-control" style="padding-right: 5px; text-align: right; font-size: large;" />            
                    @Html.Raw("※ 請確認時數計算是否正確！")
                    <br>
                    @Html.Raw("※ Please confirm if the hour calculation is correct.")
                </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.day_reason, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 7px 0 0 0;" })
                @Html.TextArea("day_reason", Model.day_reason, new { @rows="4", @class = "form-control col-md-9", @style="font-size: large;" })
            </div>
            <div class="form-group">
                @Html.HiddenFor(model => model.attach_uid)
                @if (Model.attach_added && Model.attach_uid != null)
                { 
                    @Html.LabelFor(model => model.attachment, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 5px 0 0 0;" })
                    @Html.ActionLink(Model.attachment, "Get_attachment", "Taiwan", new { pm_attach_uid = Model.attach_uid }, new { target = "_blank" })
                    @Html.ActionLink("Delete", "Go_DeleteAttachment", "Taiwan", new { pm_attach_uid = Model.attach_uid }, new { @class = "btn", @style = "margin: 0 0 0 10px;", onclick="return confirm('確認刪除此附件？');" })
                }
                else
                {
                    @Html.LabelFor(model => model.attachment, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 7px 0 0 0;" })
                    @Html.TextBoxFor(model => model.attachedFile, new { type = "file", @class = "form-control col-md-9", accept = ".pdf, .zip" })
                }
            </div>
            @if (!(bool)ViewData["isNew"])
            {
                <div class="form-group">
                    @Html.LabelFor(model => model.z_status, htmlAttributes: new { @class = "col-md-3", @style = "text-align: right; margin: 2px 0 0 0;" })
                    @Html.CheckBoxFor(x => x.z_status_chk)
                </div>
            }
        </div>
    </div>
    <div class="modal-footer">
        <input type="submit" value="儲存" @attr_html class="btn btn-primary" onclick="return confirm('確認儲存資料？');" />
    </div>
}


@if (TempData["message"] != null)
{
    <script type="text/javascript">
    var message = @Html.Raw(Json.Encode(TempData["message"]));
    alert(message);
    </script>
}

