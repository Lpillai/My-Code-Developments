@using RuntimeVariables;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;
}
@*
@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/jqueryval")
@Scripts.Render("~/bundles/unobtrusive")
*@




<style type="text/css">
</style>




<script type="text/javascript">
    $(document).ready(function () {   
    });
</script>
<script type="text/javascript">
    function onEmpChang() {
        $("#loading").fadeIn();
        var target = document.getElementById('loading');
        var spinner = new Spinner(window.opts).spin(target);

        var pm_employee = $("#pm_employee option:selected").val();
        $("#details").load('@Url.Action("Show_HR_ManagingPageDetails", "Taiwan")?&pm_account_id=' + pm_employee);
    }
    
    function pageLoad() {
        //alert('pageLoad');
        onEmpChang();
    }
    window.onload = pageLoad;
</script>




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->


<h4>@ViewBag.Path</h4>


<div class="row">
    <label class="control-label col-md-1" style="text-align: right; padding-top: 7px;">Employee</label>
    @Html.DropDownList("pm_employee", (SelectList)ViewData["List_TW_Employee"], new { @onchange="onEmpChang()", @class = "form-control col-md-1", @style = "font-size: large;" })
</div>


<div id="details">
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}

