@using RuntimeVariables;
@model tw_LeaveTaking
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = ((ViewBagPageInfo)ViewBag.PageInfo).Title;
    ViewBag.PageName = ((ViewBagPageInfo)ViewBag.PageInfo).PageName;
    ViewBag.Path = ((ViewBagPageInfo)ViewBag.PageInfo).Path;

    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}
@*
@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/jqueryval")
@Scripts.Render("~/bundles/unobtrusive")
*@



<style>
    * {
        box-sizing: border-box;
    }

    body {
        font-family: Arial, Helvetica, sans-serif;
    }

    /* Float columns side by side */
    .column {
        float: left;
        padding: 0 10px;
    }

    /* Remove extra left and right margins, due to padding */
    .row {
        margin: 0 -5px;
    }

        /* Clear floats after the columns */
        .row:after {
            content: "";
            display: table;
            clear: both;
        }

    /* Style the counter cards */
    .card {
        box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2);
        padding: 10px 16px 1px 16px;
        text-align: left;
        background-color: #f1f1f1;
    }

    thead tr th {
        position: sticky;
        top: 0;
        background: #ffffff;
        text-align: center;
        z-index: 1;
        font-size: medium;
    }

    tbody td {
        font-size: large;
    }

    .table > tbody > tr > td {
        vertical-align: middle;
    }

    .table-hover tbody tr:hover td,
    .table-hover tbody tr:hover th {
        background-color: rgb(255 205 143 / 0.2);
    }
</style>




<script type="text/javascript">
</script>
<script type="text/javascript">
    $(document).ready(function () {
    });
</script>




<!-- #region Developing -->
@if (ViewBag.Dev != null)
{
    <div class="alert dev">
        <span class="closebtn">&times;</span>
        <strong>@ViewBag.Dev</strong>
    </div>
}
<style>
    .alert.dev {
        padding: 20px;
        color: white;
        opacity: 1;
        transition: opacity 0.6s;
        margin-bottom: 15px;
        background-color: hotpink;
        font-size: larger;
    }

    .closebtn {
        margin-left: 15px;
        color: white;
        font-weight: bold;
        float: right;
        font-size: 22px;
        line-height: 20px;
        cursor: pointer;
        transition: 0.3s;
    }

        .closebtn:hover {
            color: black;
        }
</style>
<script type='text/javascript'>
    var close = document.getElementsByClassName("closebtn");
    for (var i = 0; i < close.length; i++) {
        close[i].onclick = function () {
            var div = this.parentElement;
            div.style.opacity = "0";
            setTimeout(function () { div.style.display = "none"; }, 600);
        }
    }
</script>
<!-- #endregion -->




<h4>@ViewBag.Path</h4>




<div class="modal fade" id="detailsModal" tabindex="-1" role="dialog" aria-labelledby="detailsModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content" id="myDetails">
        </div>
    </div>
</div>




<div class="modal fade" id="cardModal" tabindex="-1" role="dialog" aria-labelledby="cardModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content" id="myCard">
            @using (Html.BeginForm("Go_AddCardStamp", "Taiwan", null, FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&Chi;</span>
                    </button>
                    <h4 class="modal-title" id="cardModalLabel">補打卡資料</h4>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-3" style="text-align: right; padding-top: 7px;">
                            @Html.Label("補打卡時間", htmlAttributes: new { @class = "control-label" })
                        </div>
                        <div class="col-md-7">
                            @Html.TextBox("pmStamp", "", new { type = "datetime-local", @class = "form-control", @style = "font-size: large;" })
                        </div>
                        <div class="col-md-2">
                            <input type="submit" value="儲存" @attr_html class="btn btn-primary" onclick="return confirm('確認儲存？');" />
                        </div>
                    </div>
                </div>
                if (Model.theCards != null && Model.theCards.Count() > 0)
                {
                    <div class="modal-footer">
                        <div class="row">
                            <div class="col-md-3" style="text-align: right; padding-top: 7px;">
                                @Html.DisplayNameFor(model => model.theCards.FirstOrDefault().card_stamp)
                            </div>
                            <div class="col-md-7">
                                <table>
                                    <tbody>
                                        @{ 
                                            int j = 0;
                                            foreach (var item in Model.theCards)
                                            {
                                                j++;
                                                <tr>
                                                    <td>
                                                        @Html.DisplayFor(modelItem => item.card_stamp)
                                                    </td>
                                                    <td style="padding-left: 10px;">
                                                        @Html.DisplayFor(modelItem => item.z_status)
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>




<div class="row" style="padding: 10px;">
    <a href="#cardModal" class="btn btn-default action_btn" data-toggle="modal">補打卡資料</a>
    &nbsp;
    @Ajax.ActionLink("新增請假", "ShowLeaveTakingDetails", "Taiwan", new { pm_source = "LeaveTakingManagement", pm_apply_uid = 0, pm_isNew = true }, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal", @class="btn btn-default action_btn" })
</div>




<div class="row" style="margin: 10px 0 0 0;">
    <div class="column" style="width: 17%;">
        <div class="card">
            <h3 style="text-align: center">年度累計</h3>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="text-align: center;">
                            @Html.DisplayNameFor(model => model.theStatics.FirstOrDefault().day_name)
                        </th>
                        <th style="text-align: center; width: 90px; max-width: 90px;">
                            @Html.DisplayNameFor(model => model.theStatics.FirstOrDefault().sumDays)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model.theStatics == null || Model.theStatics.Count() <= 0)
                        {
                            <tr>
                                <td colspan="2" style="text-align:center;">No data found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.theStatics)
                            {
                                <tr>
                                    <td>
                                        @*@Html.DisplayFor(modelItem => item.day_name)*@
                                        @Html.Raw(item.day_name.Replace("\r\n","<br>"))
                                    </td>
                                    <td align="right" style="padding-right: 20px;">
                                        @Html.DisplayFor(modelItem => item.sumDays)
                                    </td>
                                </tr>
                            }

                        }
                    } 
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="column" style="width: 50%;">
        <div class="card">
            <h3 style="text-align: center">可用時數</h3>
            
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="text-align: center;">
                            @Html.DisplayNameFor(model => model.theAvailable.FirstOrDefault().day_name)
                        </th>
                        <th style="text-align: center; width: 130px; max-width: 130px;">
                            @Html.DisplayNameFor(model => model.theAvailable.FirstOrDefault().available_start)
                        </th>
                        <th style="text-align: center; width: 130px; max-width: 130px;">
                            @Html.DisplayNameFor(model => model.theAvailable.FirstOrDefault().available_end)
                        </th>
                        <th style="text-align: center; width: 90px; max-width: 90px;">
                            @Html.DisplayNameFor(model => model.theAvailable.FirstOrDefault().available_hours)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model.theAvailable == null || Model.theAvailable.Count() <= 0)
                        {
                            <tr>
                                <td colspan="4" style="text-align:center;">No data found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.theAvailable)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.day_name)
                                        @*@Html.Raw(item.day_name.Replace("\r\n","<br>"))*@
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.available_start)
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.available_end)
                                    </td>
                                    <td align="right" style="padding-right: 20px;">
                                        @Html.DisplayFor(modelItem => item.available_hours)
                                    </td>
                                </tr>
                            }

                        }
                    } 
                </tbody>
            </table>
        </div>
    </div>

    <div class="column" style="width: 30%;">
        <div class="card">
            <h3 style="text-align: center">今天有人請假</h3>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="text-align: center;">
                            @Html.DisplayNameFor(model => model.DayOffToday.FirstOrDefault().name)
                        </th>
                        <th style="text-align: center; width: 160px; max-width: 160px;">
                            @Html.DisplayNameFor(model => model.DayOffToday.FirstOrDefault().day_start)
                        </th>
                        <th style="text-align: center; width: 160px; max-width: 160px;">
                            @Html.DisplayNameFor(model => model.DayOffToday.FirstOrDefault().day_end)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model.DayOffToday == null || Model.DayOffToday.Count() <= 0)
                        {
                            <tr>
                                <td colspan="3" style="text-align:center;">No data found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.DayOffToday)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.name)
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.day_start)
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.day_end)
                                    </td>
                                </tr>
                            }

                        }
                    } 
                </tbody>
            </table>
        </div>
    </div>
</div>


<div class="row" style="margin: 15px 0 0 0;">
    <div class="column" style="width: 99%;">
        <div class="card">
            <h3 style="text-align: center;">請假紀錄</h3>
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="text-align: center; width: 40px; max-width: 40px;">
                            @if (Model.theApplys == null || Model.theApplys.Count() <= 0)
                            {
                                @Html.Raw("0")
                            }
                            else
                            {
                                @Model.theApplys.Count().ToString()
                            }
                        </th>
                        <th style="text-align: center; width: 60px; max-width: 60px;">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().apply_uid)
                        </th>
                        <th style="text-align: center; width: 90px; max-width: 90px;">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().day_year)
                        </th>
                        <th style="text-align: center">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().day_name)
                        </th>
                        <th style="text-align: center; width: 160px; max-width: 160px;">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().day_start)
                        </th>
                        <th style="text-align: center; width: 160px; max-width: 160px;">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().day_end)
                        </th>
                        <th style="text-align: center; width: 90px; max-width: 90px;">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().day_hours)
                        </th>
                        <th style="text-align: center">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().day_reason)
                        </th>
                        <th style="text-align: center; width: 90px; max-width: 90px;">
                            @Html.DisplayNameFor(model => model.theApplys.FirstOrDefault().sts)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model.theApplys == null || Model.theApplys.Count() <= 0)
                        {
                            <tr>
                                <td colspan="8" style="text-align:center;">No data found.</td>
                            </tr>
                        }
                        else
                        {
                            int i = 0;
                            foreach (var item in Model.theApplys)
                            {
                                i++;
                                string theUid = item.apply_uid.ToString("0000");
                                <tr>
                                    <td align="right">
                                        @Html.Raw(i)
                                    </td>
                                    @if(item.steps < 3 && ViewData["pm_account_id"].ToString() == ViewData["session_account"].ToString() && 
                                        (item.day_start.Year * 100 + item.day_start.Month >= DateTime.Now.Year * 100 + DateTime.Now.Month))
                                    {
                                        <td align="center">
                                            @Ajax.ActionLink(@theUid, "ShowLeaveTakingDetails", "Taiwan", new { pm_source = "LeaveTakingManagement", pm_apply_uid = @item.apply_uid, pm_isNew = false }, new AjaxOptions { UpdateTargetId = "myDetails", InsertionMode = InsertionMode.Replace }, new { data_toggle = "modal", data_target = "#detailsModal" })
                                        </td>
                                    }
                                    else
                                    {
                                        <td align="center">
                                            @Html.Raw(theUid)
                                        </td>
                                    }
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.day_year)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.day_name)
                                        @*@Html.Raw(item.day_name.Replace("\r\n","<br>"))*@
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.day_start)
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.day_end)
                                    </td>
                                    <td align="right" style="padding-right: 20px;">
                                        @Html.DisplayFor(modelItem => item.day_hours)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.day_reason)
                                    </td>
                                    <td align="center">
                                        @Html.DisplayFor(modelItem => item.sts)
                                    </td>
                                </tr>
                            }

                        }
                    } 
                </tbody>
            </table>
        </div>
    </div>
</div>




@if (TempData["message"] != null)
{
    <script type="text/javascript">
        var message = @Html.Raw(Json.Encode(TempData["message"]));
        alert(message);
    </script>
}
