@model RuntimeVariables.tw_CardStamp

@{
    object attr_helper = null;
    object attr_html = "";
    object attr_css = "";
    if (!ViewBag.authorized)
    {
        attr_helper = new { disabled = "disabled" };
        attr_html = "disabled";
        attr_css = "isDisabled";
    }
}



<style>
    input[type=checkbox] {
        background-color: white;
        border-radius: 2px;
        outline: 1px solid skyblue;
        -webkit-appearance: none;
        -moz-appearance: none;
        width: 17px;
        height: 17px;
        cursor: pointer;
        position: relative;
    }

        input[type=checkbox]:disabled {
            outline: 1px solid lightgray;
        }

        input[type=checkbox]:focus {
            outline: 1px solid rgba(0, 0, 0, 0.2);
        }

        input[type=checkbox]:checked {
            background-color: #409fd6;
            background: #409fd6 url("data:image/gif;base64,R0lGODlhCwAKAIABAP////3cnSH5BAEKAAEALAAAAAALAAoAAAIUjH+AC73WHIsw0UCjglraO20PNhYAOw==") 3px 3px no-repeat;
        }
</style>




<script type="text/javascript">
    function onCheck() {
        if (document.getElementById('chk_z_status').checked)
            document.getElementById('z_status').value = 'D';
        else
            document.getElementById('z_status').value = '';
        //alert(document.getElementById('z_status').value);
    }
</script>


<script type="text/javascript">
    document.getElementById('chk_z_status').checked = false;
    var module = @Html.Raw(Json.Encode(@Model));
    if (module.z_status === 'D')
        document.getElementById('chk_z_status').checked = true;
</script>




@using (Html.BeginForm("Go_SaveCardStampDetails", "Taiwan", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.card_cd)
    @Html.HiddenFor(model => model.card_stamp)
    @Html.HiddenFor(model => model.z_status)

    <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&Chi;</span>
        </button>
        <h4 class="modal-title" id="detailsModalLabel">
            <span>@Model.card_cd - @Html.DisplayFor(modelItem => modelItem.card_stamp)</span>
        </h4>
    </div>
    <div class="modal-body">
        <div class="form-horizontal">
            <div class="form-group">
                @Html.LabelFor(model => model.override_stamp, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right; margin: 7px 0 0 0;" })
                <input type="datetime-local" name="override_stamp" value="@Model.card_stamp.ToString()" class="form-control col-md-8" style="font-size: large;" />
            </div>
            <div class="form-group">
                <p style="margin: 9px 0 0 0;">
                    @Html.LabelFor(model => model.full_name, htmlAttributes: new { @class = "col-md-4", @style = "text-align: right;" })
                    @if(!string.IsNullOrWhiteSpace(Model.account_id))
                    {
                        @Html.DisplayFor(modelItem => modelItem.full_name, new { @class = "col-md-8", @style = "font-size: large;" })
                    }
                    else
                    {
                        @Html.DropDownList("account_id", (SelectList)ViewData["List_TW_Employee"], new { @class = "form-control col-md-8", @style = "font-size: large;" })
                    }
                </p>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.chk_z_status, htmlAttributes: new { @class = "control-label col-md-4" })
                <div class="col-md-8" style="padding: 5px 0 0 14px;">
                    <input type="checkbox" id="chk_z_status" value="" onclick="javascript:onCheck();" />
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <input type="submit" value="儲存" @attr_html class="btn btn-primary" onclick="return confirm('儲存打卡紀錄？');" />
    </div>
}


@if (TempData["message"] != null)
{
    <script type="text/javascript">
    var message = @Html.Raw(Json.Encode(TempData["message"]));
    alert(message);
    </script>
}

